#### 4.2.2 Form Block

```typescript
interface FormBlockContent {
  // Form fields
  fields: Array<{
    id: string;
    type: "text" | "email" | "phone" | "number" | "textarea" | "select" | "multi_select" | "checkbox" | "radio" | "date" | "file" | "hidden" | "address" | "name_first_last";
    label: string;
    placeholder: string;
    required: boolean;
    width: "full" | "half" | "third";          // Grid width
    validation: {
      pattern: string | null;                  // Regex
      minLength: number | null;
      maxLength: number | null;
      min: number | null;
      max: number | null;
      customMessage: string | null;
    };
    options: string[];                         // For select/radio/checkbox
    defaultValue: string;
    
    // Map to contact field
    contactField: string | null;               // "email", "firstName", "phone", "custom.industry"
    
    // Conditional display
    showIf: {
      fieldId: string;
      operator: "equals" | "not_equals" | "contains" | "is_filled";
      value: string;
    } | null;
  }>;
  
  // Submit button
  submitText: string;                          // "Get Started"
  submitStyle: "solid" | "outline" | "gradient";
  submitColor: string;
  submitTextColor: string;
  submitSize: "sm" | "md" | "lg" | "xl";
  submitFullWidth: boolean;
  submitIcon: string | null;
  
  // Success action
  successAction: "message" | "redirect" | "popup" | "next_step";
  successMessage: string;                      // "Thanks! Check your email."
  successRedirectUrl: string;
  successPopupPageId: string | null;
  
  // Error handling
  errorMessage: string;
  
  // Integrations triggered on submit
  integrationActions: Array<{
    integrationId: string;
    action: string;                            // "add_contact", "add_to_list", "create_deal", "send_webhook"
    config: Record<string, any>;
  }>;
  
  // Tags to add to contact on submit
  addTags: string[];
  
  // Segment to add contact to
  addToSegmentId: string | null;
  
  // Double opt-in
  doubleOptIn: boolean;
  
  // Anti-spam
  honeypot: boolean;
  recaptcha: boolean;
  
  // Layout
  layout: "stacked" | "inline" | "grid";
  labelPosition: "above" | "inside" | "left";
  fieldGap: string;                            // "12px"
}
```

