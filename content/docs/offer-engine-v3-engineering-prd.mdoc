## 4. BLOCK SYSTEM — EVERY BLOCK TYPE

### 4.1 Block Type Registry

Every block type must implement this interface:

```typescript
interface BlockTypeDefinition {
  type: string;                    // "hero", "text", etc.
  name: string;                    // "Hero Section"
  category: BlockCategory;         // "layout" | "content" | "forms" | "social" | "commerce" | "advanced"
  icon: string;                    // Lucide icon name
  description: string;
  
  // Default content when block is first added
  defaultContent: () => BlockContent;
  
  // Default style
  defaultStyle: () => Partial<BlockStyle>;
  
  // Render in builder canvas (editable)
  BuilderComponent: React.FC<BuilderBlockProps>;
  
  // Render in published page (static/hydrated)
  PublishedComponent: React.FC<PublishedBlockProps>;
  
  // Properties panel for this block type
  PropertiesComponent: React.FC<PropertiesProps>;
  
  // Can this block contain children?
  acceptsChildren: boolean;
  
  // What child types are allowed?
  allowedChildTypes?: string[];
  
  // Constraints
  maxInstances?: number;           // Max of this type per page
  requiredParent?: string;         // Must be inside this type
}

// Registry
const BLOCK_TYPES: Record<string, BlockTypeDefinition> = {
  // LAYOUT
  section: { ... },
  columns: { ... },
  grid: { ... },
  
  // CONTENT
  hero: { ... },
  text: { ... },
  image: { ... },
  video: { ... },
  button: { ... },
  divider: { ... },
  spacer: { ... },
  
  // FORMS
  form: { ... },
  quiz: { ... },
  survey: { ... },
  
  // SOCIAL PROOF
  testimonial: { ... },
  logo_bar: { ... },
  social_proof: { ... },
  
  // COMMERCE
  pricing: { ... },
  product: { ... },
  countdown: { ... },
  comparison: { ... },
  
  // NAVIGATION
  navbar: { ... },
  footer: { ... },
  
  // FEATURES
  feature_grid: { ... },
  steps: { ... },
  faq: { ... },
  
  // ADVANCED
  custom_html: { ... },
  code_embed: { ... },
  popup_trigger: { ... },
};
```

### 4.2 Detailed Block Specifications

#### 4.2.1 Hero Block

```typescript
interface HeroBlockContent {
  // Layout variant
  layout: "center" | "left" | "right" | "split" | "video_bg";
  
  // Text content
  heading: SlateJSON;                          // Rich text
  subheading: SlateJSON;                       // Rich text
  supportingText: SlateJSON;                   // Optional paragraph
  
  // CTA buttons (1-3)
  buttons: Array<{
    text: string;
    url: string;
    action: "link" | "scroll" | "popup" | "form" | "phone" | "email";
    style: "solid" | "outline" | "ghost" | "gradient";
    size: "sm" | "md" | "lg" | "xl";
    color: string;                             // Button color override
    textColor: string;
    borderRadius: string;
    icon: string | null;                       // Lucide icon name
    iconPosition: "left" | "right";
    fullWidth: boolean;
  }>;
  
  // Media
  backgroundType: "color" | "image" | "video" | "gradient";
  backgroundImage: string | null;
  backgroundVideo: string | null;              // URL or embed
  backgroundOverlayColor: string;              // "rgba(0,0,0,0.5)"
  backgroundOverlayOpacity: number;            // 0-1
  
  // Side image (for split layout)
  sideImage: string | null;
  sideImagePosition: "left" | "right";
  
  // Trust badges
  trustBadges: Array<{ src: string; alt: string }>;
  
  // Height
  minHeight: string;                           // "80vh", "600px", "auto"
  
  // Vertical alignment
  verticalAlign: "top" | "center" | "bottom";
}

