## 9. A/B TESTING ENGINE

### 9.1 Variant Assignment (Server-Side, No Flicker)

```typescript
// convex/experiments.ts

// Assign variant BEFORE rendering HTML — zero flicker
export const assignVariant = internalAction({
  args: {
    experimentId: v.id("experiments"),
    sessionId: v.string(),
  },
  handler: async (ctx, args) => {
    const experiment = await ctx.runQuery(internal.experiments.get, { id: args.experimentId });
    if (!experiment || experiment.status !== "running") return null;
    
    // Check existing assignment (sticky sessions)
    const session = await ctx.runQuery(internal.sessions.getByAnonymousId, { 
      anonymousId: args.sessionId 
    });
    
    if (session?.experimentAssignments?.[experiment._id]) {
      return session.experimentAssignments[experiment._id];
    }
    
    // Assign new variant based on weights
    let assignedVariant: string;
    
    if (experiment.autoOptimize) {
      // Bayesian Thompson Sampling — pulls from Beta distribution per variant
      assignedVariant = thompsonSampling(experiment);
    } else {
      // Simple weighted random
      assignedVariant = weightedRandom(experiment.variants);
    }
    
    // Store assignment
    await ctx.runMutation(internal.sessions.setExperimentAssignment, {
      sessionId: args.sessionId,
      experimentId: experiment._id,
      variantId: assignedVariant,
    });
    
    // Track impression
    await ctx.runMutation(internal.analytics.ingestEvent, {
      websiteId: experiment.websiteId,
      type: "experiment_impression",
      metadata: {
        experimentId: experiment._id,
        variantId: assignedVariant,
        variantName: experiment.variants.find(v => v.id === assignedVariant)?.name,
      },
      timestamp: Date.now(),
    });
    
    return assignedVariant;
  },
});

// Thompson Sampling for Bayesian Bandit
function thompsonSampling(experiment: Experiment): string {
  const samples = experiment.variants.map(variant => {
    const results = experiment.results?.variantResults?.[variant.id];
    const successes = results?.conversions || 0;
    const failures = (results?.visitors || 0) - successes;
    
    // Beta distribution: Beta(successes + 1, failures + 1)
    // Use Jorgensen's approximation for sampling
    const alpha = successes + 1;
    const beta = failures + 1;
    const sample = betaSample(alpha, beta);
    
    return { variantId: variant.id, sample };
  });
  
  // Pick variant with highest sample
  return samples.reduce((best, curr) => curr.sample > best.sample ? curr : best).variantId;
}

function betaSample(alpha: number, beta: number): number {
  // Box-Muller transform approximation for Beta distribution
  const x = gammaSample(alpha);
  const y = gammaSample(beta);
  return x / (x + y);
}
```

### 9.2 Statistical Significance Calculation

```typescript
// Z-test for proportions (frequentist)
function calculateSignificance(
  controlVisitors: number,
  controlConversions: number,
  variantVisitors: number,
  variantConversions: number,
): { pValue: number; confidence: number; isSignificant: boolean; improvement: number } {
  const p1 = controlConversions / controlVisitors;
  const p2 = variantConversions / variantVisitors;
  const pPooled = (controlConversions + variantConversions) / (controlVisitors + variantVisitors);
  
  const se = Math.sqrt(pPooled * (1 - pPooled) * (1/controlVisitors + 1/variantVisitors));
  const z = (p2 - p1) / se;
  
  // Two-tailed p-value
  const pValue = 2 * (1 - normalCDF(Math.abs(z)));
  const confidence = 1 - pValue;
  const improvement = ((p2 - p1) / p1) * 100;
  
  return {
    pValue,
    confidence,
    isSignificant: confidence >= (experiment.confidenceLevel || 0.95),
    improvement,
  };
}

// Experiment evaluation cron (runs every hour)
export const evaluateExperiments = internalMutation({
  handler: async (ctx) => {
    const running = await ctx.db
      .query("experiments")
      .filter(q => q.eq(q.field("status"), "running"))
      .collect();
    
    for (const experiment of running) {
      // Aggregate event data per variant
      const variantResults: Record<string, any> = {};
      
      for (const variant of experiment.variants) {
        const impressions = await ctx.db
          .query("events")
          .withIndex("by_website_type", q => 
            q.eq("websiteId", experiment.websiteId).eq("type", "experiment_impression")
          )
          .filter(q => q.eq(q.field("metadata.variantId"), variant.id))
          .collect();
        
        const goalEvents = await getGoalEvents(ctx, experiment, variant.id);
        
        variantResults[variant.id] = {
          visitors: impressions.length,
          conversions: goalEvents.length,
          rate: impressions.length > 0 ? goalEvents.length / impressions.length : 0,
        };
      }
      
      // Calculate significance for each variant vs control
      const control = experiment.variants.find(v => v.isControl);
      const controlResults = variantResults[control.id];
      
      let winner = null;
      let bestImprovement = 0;
      
      for (const variant of experiment.variants.filter(v => !v.isControl)) {
        const vr = variantResults[variant.id];
        const sig = calculateSignificance(
          controlResults.visitors, controlResults.conversions,
          vr.visitors, vr.conversions
        );
        
        variantResults[variant.id] = { ...vr, ...sig };
        
        if (sig.isSignificant && sig.improvement > bestImprovement) {
          winner = variant.id;
          bestImprovement = sig.improvement;
        }
      }
      
      // Update experiment results
      await ctx.db.patch(experiment._id, {
        results: {
          totalVisitors: Object.values(variantResults).reduce((s, v) => s + v.visitors, 0),
          startedAt: experiment.startedAt,
          variantResults,
          winner,
          isSignificant: winner !== null,
        },
      });
      
      // Auto-end if significant and auto-end enabled
      if (winner && experiment.autoEndOnSignificance) {
        const minSample = experiment.minimumSampleSize || 100;
        const allAboveMinSample = Object.values(variantResults).every(v => v.visitors >= minSample);
        
        if (allAboveMinSample) {
          await ctx.db.patch(experiment._id, {
            status: "completed",
            endedAt: Date.now(),
          });
        }
      }
    }
  },
});
```

### 9.3 Experiment UI Components

```typescript
// Builder: Experiment creation wizard
interface ExperimentWizardSteps {
  step1_type: {
    // Choose: Page test, Block test, Redirect test, Multivariate
    type: ExperimentType;
  };
  step2_variants: {
    // Add variants with traffic splits
    // For page test: select/create variant pages
    // For block test: select blocks to change
    // Visual editor for each variant
    variants: ExperimentVariant[];
  };
  step3_goal: {
    // Define what counts as success
    // Form submission, button click, page view, custom event, revenue
    primaryGoal: ExperimentGoal;
    secondaryGoals: ExperimentGoal[];
  };
  step4_targeting: {
    // Who sees the test
    // All visitors, specific segment, URL rules
    audience: SegmentId | null;
    urlRules: UrlRule[];
  };
  step5_settings: {
    // Confidence level (90%, 95%, 99%)
    // Minimum sample size
    // Minimum run time
    // Auto-optimize (Bayesian)
    // Auto-end on significance
    confidenceLevel: number;
    minimumSampleSize: number;
    minimumRunDays: number;
    autoOptimize: boolean;
    autoEndOnSignificance: boolean;
  };
}

// Results dashboard
interface ExperimentResultsView {
  // Summary card: Winner / No winner yet / Running
  // Per-variant cards:
  //   - Visitors, conversions, rate
  //   - Improvement vs control (with CI)
  //   - Confidence level (progress bar to target)
  //   - Daily trend chart
  // Statistical details panel
  // "Apply winner" button → publishes winning variant as main
}
```

