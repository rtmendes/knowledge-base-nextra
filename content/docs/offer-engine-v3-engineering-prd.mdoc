## 11. IDENTITY RESOLUTION SYSTEM

### 11.1 Tracking Script Architecture

```typescript
// published/tracking.ts — Lightweight tracking script (~3KB gzipped)
// Loaded async on every published page

(function() {
  const WEBSITE_ID = document.currentScript.dataset.website;
  const PAGE_ID = document.currentScript.dataset.page;
  const API_BASE = document.currentScript.src.replace("/tracking.js", "");
  
  // ── Session Management ──
  function getOrCreateSessionId(): string {
    let sid = getCookie("oe_sid");
    if (!sid) {
      sid = generateUUID();
      setCookie("oe_sid", sid, 30); // 30 min expiry, refreshed on activity
    }
    return sid;
  }
  
  function getOrCreateVisitorId(): string {
    let vid = localStorage.getItem("oe_vid");
    if (!vid) {
      vid = generateUUID();
      localStorage.setItem("oe_vid", vid);
    }
    return vid;
  }
  
  // ── Fingerprinting (lightweight, no external library) ──
  function generateFingerprint(): string {
    const components = [
      navigator.userAgent,
      navigator.language,
      screen.colorDepth,
      screen.width + "x" + screen.height,
      new Date().getTimezoneOffset(),
      navigator.hardwareConcurrency,
      navigator.maxTouchPoints,
      // Canvas fingerprint
      (() => {
        try {
          const canvas = document.createElement("canvas");
          const ctx = canvas.getContext("2d");
          ctx.textBaseline = "top";
          ctx.font = "14px Arial";
          ctx.fillText("oe-fp", 2, 2);
          return canvas.toDataURL().slice(-50);
        } catch { return ""; }
      })(),
      // WebGL renderer
      (() => {
        try {
          const gl = document.createElement("canvas").getContext("webgl");
          const ext = gl.getExtension("WEBGL_debug_renderer_info");
          return ext ? gl.getParameter(ext.UNMASKED_RENDERER_WEBGL) : "";
        } catch { return ""; }
      })(),
    ];
    
    // Simple hash
    return hashComponents(components.join("|||"));
  }
  
  // ── UTM Parsing ──
  function parseUtmParams(): object {
    const params = new URLSearchParams(window.location.search);
    return {
      source: params.get("utm_source"),
      medium: params.get("utm_medium"),
      campaign: params.get("utm_campaign"),
      term: params.get("utm_term"),
      content: params.get("utm_content"),
    };
  }
  
  // ── Event Tracking ──
  const queue: any[] = [];
  let flushTimer: number | null = null;
  
  function track(type: string, metadata?: any) {
    queue.push({
      websiteId: WEBSITE_ID,
      pageId: PAGE_ID,
      sessionId: getOrCreateSessionId(),
      visitorId: getOrCreateVisitorId(),
      fingerprintId: window.__OE_FINGERPRINT__,
      type,
      metadata,
      url: window.location.href,
      referrer: document.referrer,
      timestamp: Date.now(),
    });
    
    // Batch flush every 2 seconds or when queue hits 10
    if (queue.length >= 10) flush();
    else if (!flushTimer) flushTimer = setTimeout(flush, 2000);
  }
  
  function flush() {
    if (queue.length === 0) return;
    const batch = queue.splice(0);
    flushTimer = null;
    
    // Use sendBeacon for reliability (works on page unload)
    if (navigator.sendBeacon) {
      navigator.sendBeacon(`${API_BASE}/api/track/batch`, JSON.stringify(batch));
    } else {
      fetch(`${API_BASE}/api/track/batch`, {
        method: "POST",
        body: JSON.stringify(batch),
        keepalive: true,
      });
    }
  }
  
  // ── Scroll Depth Tracking ──
  const scrollMilestones = [25, 50, 75, 100];
  let maxScroll = 0;
  
  window.addEventListener("scroll", () => {
    const scrollPercent = Math.round(
      (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100
    );
    
    for (const milestone of scrollMilestones) {
      if (scrollPercent >= milestone && maxScroll < milestone) {
        track("scroll_depth", { percent: milestone });
      }
    }
    maxScroll = Math.max(maxScroll, scrollPercent);
  }, { passive: true });
  
  // ── Page View ──
  window.__OE_FINGERPRINT__ = generateFingerprint();
  window.__OE_SESSION_ID__ = getOrCreateSessionId();
  window.__OE_PAGE_ID__ = PAGE_ID;
  window.__OE_UTM__ = parseUtmParams();
  window.__OE_TRACK__ = track;
  
  // Initialize session on server
  fetch(`${API_BASE}/api/session/init`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      websiteId: WEBSITE_ID,
      sessionId: getOrCreateSessionId(),
      visitorId: getOrCreateVisitorId(),
      fingerprintId: window.__OE_FINGERPRINT__,
      url: window.location.href,
      referrer: document.referrer,
      utm: parseUtmParams(),
      device: /Mobile|Android/i.test(navigator.userAgent) ? "mobile" : /Tablet|iPad/i.test(navigator.userAgent) ? "tablet" : "desktop",
      browser: detectBrowser(),
      os: detectOS(),
      screenWidth: window.innerWidth,
      screenHeight: window.innerHeight,
      language: navigator.language,
      timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
    }),
  });
  
  track("page_view", { url: window.location.href, title: document.title });
  
  // Flush on page unload
  window.addEventListener("beforeunload", flush);
  window.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "hidden") flush();
  });
  
  // Run personalization
  personalizeContent();
})();
```

### 11.2 Identity Stitching (Server-Side)

```typescript
// convex/identity.ts

// When a form is submitted with an email, link the anonymous session to a contact
export const linkSessionToContact = mutation({
  args: {
    websiteId: v.id("websites"),
    sessionId: v.string(),
    email: v.string(),
    additionalFields: v.optional(v.any()),
  },
  handler: async (ctx, args) => {
    // 1. Find or create contact by email
    let contact = await ctx.db
      .query("contacts")
      .withIndex("by_email", q => q.eq("websiteId", args.websiteId).eq("email", args.email))
      .first();
    
    if (!contact) {
      const contactId = await ctx.db.insert("contacts", {
        websiteId: args.websiteId,
        email: args.email,
        ...args.additionalFields,
        anonymousIds: [],
        firstSeenAt: Date.now(),
        lastSeenAt: Date.now(),
        totalVisits: 1,
        totalPageViews: 0,
        totalFormSubmissions: 1,
        engagementScore: 10,
        createdAt: Date.now(),
        updatedAt: Date.now(),
      });
      contact = await ctx.db.get(contactId);
    }
    
    // 2. Get current session
    const session = await ctx.db
      .query("sessions")
      .withIndex("by_anonymous", q => q.eq("websiteId", args.websiteId).eq("anonymousId", args.sessionId))
      .first();
    
    if (session) {
      // Link session → contact
      await ctx.db.patch(session._id, { contactId: contact._id });
      
      // 3. Find ALL previous sessions with same fingerprint and link them
      if (session.fingerprintId) {
        const prevSessions = await ctx.db
          .query("sessions")
          .withIndex("by_fingerprint", q => q.eq("websiteId", args.websiteId).eq("fingerprintId", session.fingerprintId))
          .collect();
        
        for (const prev of prevSessions) {
          if (!prev.contactId) {
            await ctx.db.patch(prev._id, { contactId: contact._id });
          }
        }
        
        // Update contact fingerprint
        await ctx.db.patch(contact._id, { fingerprintId: session.fingerprintId });
      }
      
      // 4. Add anonymous ID to contact's list
      const ids = new Set(contact.anonymousIds || []);
      ids.add(args.sessionId);
      if (session.fingerprintId) ids.add(session.fingerprintId);
      
      await ctx.db.patch(contact._id, {
        anonymousIds: Array.from(ids),
        lastSeenAt: Date.now(),
        // Merge session data into contact
        country: contact.country || session.country,
        city: contact.city || session.city,
        device: contact.device || session.device,
        browser: contact.browser || session.browser,
        os: contact.os || session.os,
        firstTouchUtm: contact.firstTouchUtm || session.utm,
        lastTouchUtm: session.utm || contact.lastTouchUtm,
        updatedAt: Date.now(),
      });
      
      // 5. Re-attribute all anonymous events to this contact
      const anonEvents = await ctx.db
        .query("events")
        .withIndex("by_session", q => q.eq("sessionId", session._id))
        .filter(q => q.eq(q.field("contactId"), undefined))
        .collect();
      
      for (const event of anonEvents) {
        await ctx.db.patch(event._id, { contactId: contact._id });
      }
    }
    
    // 6. Recalculate engagement score
    await recalculateEngagementScore(ctx, contact._id);
    
    return contact._id;
  },
});

// Engagement scoring rules
async function recalculateEngagementScore(ctx: any, contactId: Id<"contacts">) {
  const contact = await ctx.db.get(contactId);
  
  let score = 0;
  
  // Visit frequency (0-25 pts)
  score += Math.min(25, (contact.totalVisits || 0) * 5);
  
  // Page views (0-20 pts)
  score += Math.min(20, (contact.totalPageViews || 0) * 2);
  
  // Form submissions (0-25 pts)
  score += Math.min(25, (contact.totalFormSubmissions || 0) * 10);
  
  // Recency (0-15 pts)
  const daysSinceLastSeen = contact.lastSeenAt 
    ? Math.floor((Date.now() - contact.lastSeenAt) / 86400000) 
    : 999;
  if (daysSinceLastSeen <= 1) score += 15;
  else if (daysSinceLastSeen <= 7) score += 10;
  else if (daysSinceLastSeen <= 30) score += 5;
  
  // Has email (0-10 pts)
  if (contact.email) score += 10;
  
  // Has completed quiz (0-5 pts)
  if (contact.quizResponses && Object.keys(contact.quizResponses).length > 0) score += 5;
  
  await ctx.db.patch(contactId, { engagementScore: Math.min(100, score) });
}
```

