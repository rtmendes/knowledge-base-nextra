## 2. DATA MODEL — COMPLETE SCHEMA

### 2.1 Core Tables

```typescript
// convex/schema.ts — COMPLETE DATABASE SCHEMA

import { defineSchema, defineTable } from "convex/server";
import { v } from "convex/values";

export default defineSchema({

  // ============================================================
  // WEBSITES (multi-site support)
  // ============================================================
  websites: defineTable({
    name: v.string(),                         // "Family Gift Studio"
    domain: v.optional(v.string()),           // "wantthisoffer.com"
    customDomains: v.optional(v.array(v.string())), // ["fgs.wantthisoffer.com"]
    brandId: v.optional(v.string()),          // link to brand config
    favicon: v.optional(v.string()),          // URL to favicon
    defaultFont: v.optional(v.string()),      // "Inter"
    defaultColors: v.optional(v.object({
      primary: v.string(),                    // "#3B82F6"
      secondary: v.string(),                  // "#10B981"
      accent: v.string(),                     // "#F59E0B"
      background: v.string(),                 // "#FFFFFF"
      text: v.string(),                       // "#111827"
      muted: v.string(),                      // "#6B7280"
    })),
    trackingScript: v.optional(v.string()),   // Embed script for website
    apiKey: v.string(),                       // Public API key for this website
    secretKey: v.string(),                    // Private API key
    settings: v.optional(v.object({
      gdprEnabled: v.boolean(),
      cookieConsent: v.boolean(),
      doubleOptIn: v.boolean(),
      recaptchaEnabled: v.boolean(),
      recaptchaSiteKey: v.optional(v.string()),
      timezone: v.string(),
      dateFormat: v.string(),
      notificationEmail: v.optional(v.string()),
    })),
    createdAt: v.number(),
    updatedAt: v.number(),
  })
    .index("by_domain", ["domain"])
    .index("by_apiKey", ["apiKey"]),

  // ============================================================
  // PAGES (landing pages, popups, sticky bars, embeds)
  // ============================================================
  pages: defineTable({
    websiteId: v.id("websites"),
    name: v.string(),                         // "Summer Sale Landing Page"
    slug: v.string(),                         // "summer-sale"
    type: v.union(                            // Page type
      v.literal("landing_page"),
      v.literal("popup"),
      v.literal("sticky_bar"),
      v.literal("embed"),
      v.literal("quiz"),
      v.literal("form"),
      v.literal("campaign_step"),
    ),
    status: v.union(
      v.literal("draft"),
      v.literal("published"),
      v.literal("scheduled"),
      v.literal("paused"),
      v.literal("archived"),
    ),
    // Published version tracking
    currentVersion: v.number(),               // Incrementing version
    publishedVersion: v.optional(v.number()), // Which version is live
    publishedAt: v.optional(v.number()),
    publishedHtml: v.optional(v.string()),    // Pre-rendered HTML for published page
    publishedCss: v.optional(v.string()),     // Scoped CSS for published page
    
    // Page-level settings
    settings: v.object({
      // SEO
      metaTitle: v.optional(v.string()),
      metaDescription: v.optional(v.string()),
      ogImage: v.optional(v.string()),
      noIndex: v.optional(v.boolean()),
      canonicalUrl: v.optional(v.string()),
      
      // Layout
      maxWidth: v.optional(v.number()),       // 1200
      backgroundColor: v.optional(v.string()),
      backgroundImage: v.optional(v.string()),
      backgroundOverlay: v.optional(v.string()), // "rgba(0,0,0,0.5)"
      
      // Fonts
      headingFont: v.optional(v.string()),    // Google Font name
      bodyFont: v.optional(v.string()),
      
      // Colors (override website defaults)
      colors: v.optional(v.object({
        primary: v.optional(v.string()),
        secondary: v.optional(v.string()),
        accent: v.optional(v.string()),
        background: v.optional(v.string()),
        text: v.optional(v.string()),
      })),
      
      // Custom code injection
      headCode: v.optional(v.string()),       // <head> injection
      bodyStartCode: v.optional(v.string()),  // After <body>
      bodyEndCode: v.optional(v.string()),    // Before </body>
      customCss: v.optional(v.string()),      // Custom CSS
      
      // Popup-specific
      triggerType: v.optional(v.union(
        v.literal("immediate"),
        v.literal("delay"),
        v.literal("scroll_percent"),
        v.literal("exit_intent"),
        v.literal("click"),
        v.literal("inactivity"),
      )),
      triggerDelay: v.optional(v.number()),     // seconds
      triggerScrollPercent: v.optional(v.number()),
      triggerSelector: v.optional(v.string()),  // CSS selector for click trigger
      displayFrequency: v.optional(v.union(
        v.literal("every_visit"),
        v.literal("once_per_session"),
        v.literal("once_per_day"),
        v.literal("once_per_week"),
        v.literal("once_ever"),
      )),
      closeOnBackdropClick: v.optional(v.boolean()),
      showCloseButton: v.optional(v.boolean()),
      position: v.optional(v.union(           // Popup position
        v.literal("center"),
        v.literal("top"),
        v.literal("bottom"),
        v.literal("top_left"),
        v.literal("top_right"),
        v.literal("bottom_left"),
        v.literal("bottom_right"),
        v.literal("full_screen"),
      )),
      
      // Sticky bar specific
      stickyPosition: v.optional(v.union(
        v.literal("top"),
        v.literal("bottom"),
      )),
      stickyHeight: v.optional(v.number()),
      
      // Scheduling
      scheduleStart: v.optional(v.number()),
      scheduleEnd: v.optional(v.number()),
      
      // Targeting (which pages to show on)
      urlRules: v.optional(v.array(v.object({
        type: v.union(
          v.literal("contains"),
          v.literal("equals"),
          v.literal("starts_with"),
          v.literal("ends_with"),
          v.literal("regex"),
          v.literal("not_contains"),
        ),
        value: v.string(),
      }))),
      
      // Device targeting
      showOnDesktop: v.optional(v.boolean()),
      showOnMobile: v.optional(v.boolean()),
      showOnTablet: v.optional(v.boolean()),
    }),
    
    // Template info
    templateId: v.optional(v.id("templates")),
    templateName: v.optional(v.string()),
    
    // Campaign link
    campaignId: v.optional(v.id("campaigns")),
    campaignStepIndex: v.optional(v.number()),
    
    // Experiment link
    experimentId: v.optional(v.id("experiments")),
    isVariant: v.optional(v.boolean()),
    variantName: v.optional(v.string()),       // "A", "B", "C"
    
    // Stats cache (updated by cron)
    stats: v.optional(v.object({
      views: v.number(),
      uniqueVisitors: v.number(),
      submissions: v.number(),
      conversions: v.number(),
      conversionRate: v.number(),
      revenue: v.optional(v.number()),
    })),
    
    createdAt: v.number(),
    updatedAt: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_website_type", ["websiteId", "type"])
    .index("by_website_status", ["websiteId", "status"])
    .index("by_slug", ["websiteId", "slug"])
    .index("by_campaign", ["campaignId"])
    .index("by_experiment", ["experimentId"]),

  // ============================================================
  // BLOCKS (building blocks within pages)
  // ============================================================
  blocks: defineTable({
    pageId: v.id("pages"),
    parentBlockId: v.optional(v.id("blocks")), // For nested blocks (columns, sections)
    type: v.string(),                          // "hero", "text", "image", "button", etc.
    order: v.number(),                         // Sort position within parent
    version: v.number(),                       // Page version this belongs to
    
    // Block content (varies by type — generic JSON)
    content: v.any(),
    // Type-specific content examples:
    // TextBlock:     { richText: SlateJSON, alignment: "left"|"center"|"right" }
    // ImageBlock:    { src: string, alt: string, width: number, height: number, link: string }
    // ButtonBlock:   { text: string, url: string, action: "link"|"form"|"popup"|"scroll"|"custom", style: "solid"|"outline"|"ghost", size: "sm"|"md"|"lg"|"xl" }
    // FormBlock:     { fields: FormField[], submitText: string, redirectUrl: string, integrationId: string }
    // VideoBlock:    { provider: "youtube"|"vimeo"|"wistia"|"custom", videoId: string, autoplay: boolean, thumbnail: string }
    // HeroBlock:     { heading: SlateJSON, subheading: SlateJSON, cta: ButtonProps, backgroundImage: string, overlay: string }
    // ColumnsBlock:  { columns: number, gap: number, columnWidths: number[] }
    // CountdownBlock:{ endDate: number, expiredAction: "hide"|"show_message"|"redirect", expiredMessage: string, style: "flip"|"simple"|"circular" }
    // FAQBlock:      { items: {question: string, answer: string}[], style: "accordion"|"list" }
    // TestimonialBlock: { items: {name: string, role: string, company: string, text: string, avatar: string, rating: number}[], layout: "grid"|"carousel"|"stack" }
    // PricingBlock:  { plans: {name: string, price: string, period: string, features: string[], cta: ButtonProps, highlighted: boolean}[], layout: "columns"|"comparison" }
    // ProductBlock:  { productId: string, showPrice: boolean, showDescription: boolean, addToCartAction: string }
    // QuizBlock:     { questionId: string }
    // SurveyBlock:   { questions: {type: "text"|"radio"|"checkbox"|"scale"|"nps", question: string, options: string[]}[] }
    // SocialProofBlock: { type: "notification"|"counter"|"logos", items: any[] }
    // LogoBarBlock:  { logos: {src: string, alt: string, url: string}[], grayscale: boolean }
    // FeatureGridBlock: { features: {icon: string, title: string, description: string}[], columns: number }
    // StepsBlock:    { steps: {number: number, title: string, description: string, icon: string}[], layout: "horizontal"|"vertical" }
    // ComparisonBlock: { leftTitle: string, rightTitle: string, rows: {feature: string, left: string|boolean, right: string|boolean}[] }
    // NavbarBlock:   { logo: string, links: {text: string, url: string}[], ctaButton: ButtonProps, sticky: boolean }
    // FooterBlock:   { columns: {title: string, links: {text: string, url: string}[]}[], copyright: string, socialLinks: {platform: string, url: string}[] }
    // CustomHTMLBlock: { html: string, css: string, js: string }
    // DividerBlock:  { style: "solid"|"dashed"|"dotted"|"gradient", color: string, width: string }
    // SpacerBlock:   { height: number, mobileHeight: number }
    
    // Block-level styling
    style: v.optional(v.object({
      // Spacing
      marginTop: v.optional(v.string()),
      marginBottom: v.optional(v.string()),
      marginLeft: v.optional(v.string()),
      marginRight: v.optional(v.string()),
      paddingTop: v.optional(v.string()),
      paddingBottom: v.optional(v.string()),
      paddingLeft: v.optional(v.string()),
      paddingRight: v.optional(v.string()),
      
      // Background
      backgroundColor: v.optional(v.string()),
      backgroundImage: v.optional(v.string()),
      backgroundSize: v.optional(v.string()),
      backgroundPosition: v.optional(v.string()),
      backgroundGradient: v.optional(v.string()),
      backgroundOverlay: v.optional(v.string()),
      
      // Border
      borderWidth: v.optional(v.string()),
      borderColor: v.optional(v.string()),
      borderStyle: v.optional(v.string()),
      borderRadius: v.optional(v.string()),
      
      // Shadow
      boxShadow: v.optional(v.string()),
      
      // Size
      width: v.optional(v.string()),
      maxWidth: v.optional(v.string()),
      minHeight: v.optional(v.string()),
      
      // Visibility
      hideOnDesktop: v.optional(v.boolean()),
      hideOnMobile: v.optional(v.boolean()),
      hideOnTablet: v.optional(v.boolean()),
      
      // Animation
      animation: v.optional(v.union(
        v.literal("none"),
        v.literal("fade_in"),
        v.literal("slide_up"),
        v.literal("slide_down"),
        v.literal("slide_left"),
        v.literal("slide_right"),
        v.literal("zoom_in"),
        v.literal("bounce"),
      )),
      animationDelay: v.optional(v.number()),
      animationDuration: v.optional(v.number()),
      
      // Custom CSS class
      customClass: v.optional(v.string()),
      customCss: v.optional(v.string()),
    })),
    
    // Mobile overrides
    mobileStyle: v.optional(v.any()),          // Same shape as style, applied at <768px
    tabletStyle: v.optional(v.any()),          // Same shape as style, applied at 768-1024px
    
    // Conditional visibility (personalization)
    visibilityRules: v.optional(v.array(v.object({
      field: v.string(),                       // "segment", "utm_source", "device", "returning", "country"
      operator: v.string(),                    // "equals", "not_equals", "contains", "in"
      value: v.any(),                          // Comparison value
    }))),
    
    createdAt: v.number(),
    updatedAt: v.number(),
  })
    .index("by_page", ["pageId"])
    .index("by_page_version", ["pageId", "version"])
    .index("by_parent", ["parentBlockId"]),

  // ============================================================
  // TEMPLATES
  // ============================================================
  templates: defineTable({
    name: v.string(),
    description: v.optional(v.string()),
    thumbnail: v.optional(v.string()),         // Screenshot URL
    category: v.union(
      v.literal("landing_page"),
      v.literal("popup"),
      v.literal("sticky_bar"),
      v.literal("embed"),
      v.literal("quiz"),
      v.literal("form"),
      v.literal("campaign"),
    ),
    subcategory: v.optional(v.string()),       // "lead_gen", "sales", "webinar", etc.
    industry: v.optional(v.string()),          // "ecommerce", "saas", "agency", etc.
    tags: v.optional(v.array(v.string())),
    // Template data = serialized page + blocks
    pageSettings: v.any(),                     // Page settings object
    blocks: v.any(),                           // Array of block objects (content + style + order)
    // Template metadata
    isSystem: v.boolean(),                     // Built-in vs user-created
    isPublic: v.boolean(),                     // Available to all users
    usageCount: v.optional(v.number()),
    createdBy: v.optional(v.string()),
    createdAt: v.number(),
    updatedAt: v.number(),
  })
    .index("by_category", ["category"])
    .index("by_subcategory", ["category", "subcategory"]),

  // ============================================================
  // CONTACTS (leads/visitors)
  // ============================================================
  contacts: defineTable({
    websiteId: v.id("websites"),
    email: v.optional(v.string()),
    phone: v.optional(v.string()),
    firstName: v.optional(v.string()),
    lastName: v.optional(v.string()),
    company: v.optional(v.string()),
    
    // Identity resolution
    fingerprintId: v.optional(v.string()),     // Browser fingerprint
    anonymousIds: v.optional(v.array(v.string())), // All anonymous session IDs linked
    
    // Enrichment data
    country: v.optional(v.string()),
    region: v.optional(v.string()),
    city: v.optional(v.string()),
    timezone: v.optional(v.string()),
    language: v.optional(v.string()),
    device: v.optional(v.string()),            // "desktop", "mobile", "tablet"
    browser: v.optional(v.string()),
    os: v.optional(v.string()),
    
    // Attribution
    firstTouchUtm: v.optional(v.object({
      source: v.optional(v.string()),
      medium: v.optional(v.string()),
      campaign: v.optional(v.string()),
      term: v.optional(v.string()),
      content: v.optional(v.string()),
    })),
    lastTouchUtm: v.optional(v.object({
      source: v.optional(v.string()),
      medium: v.optional(v.string()),
      campaign: v.optional(v.string()),
      term: v.optional(v.string()),
      content: v.optional(v.string()),
    })),
    referrer: v.optional(v.string()),
    landingPage: v.optional(v.string()),
    
    // Engagement
    totalVisits: v.optional(v.number()),
    totalPageViews: v.optional(v.number()),
    totalFormSubmissions: v.optional(v.number()),
    lastSeenAt: v.optional(v.number()),
    firstSeenAt: v.optional(v.number()),
    
    // Scoring
    engagementScore: v.optional(v.number()),   // 0-100
    leadScore: v.optional(v.number()),         // Custom scoring rules
    
    // Custom fields (flexible key-value)
    customFields: v.optional(v.any()),         // { "industry": "saas", "company_size": "50-100" }
    
    // Tags
    tags: v.optional(v.array(v.string())),
    
    // Segment membership (cached)
    segments: v.optional(v.array(v.id("segments"))),
    
    // Quiz/survey responses
    quizResponses: v.optional(v.any()),        // { quizId: { answers: [], score: number, result: string } }
    
    // Integration IDs
    ghlContactId: v.optional(v.string()),
    shopifyCustomerId: v.optional(v.string()),
    stripeCustomerId: v.optional(v.string()),
    
    createdAt: v.number(),
    updatedAt: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_email", ["websiteId", "email"])
    .index("by_fingerprint", ["websiteId", "fingerprintId"])
    .index("by_score", ["websiteId", "engagementScore"]),

  // ============================================================
  // VISITOR SESSIONS
  // ============================================================
  sessions: defineTable({
    websiteId: v.id("websites"),
    contactId: v.optional(v.id("contacts")),   // Linked after identification
    anonymousId: v.string(),                   // Cookie-based session ID
    fingerprintId: v.optional(v.string()),
    
    // Session data
    startedAt: v.number(),
    lastActivityAt: v.number(),
    pageViews: v.number(),
    duration: v.optional(v.number()),          // seconds
    
    // Current visit context
    currentUrl: v.optional(v.string()),
    referrer: v.optional(v.string()),
    utm: v.optional(v.object({
      source: v.optional(v.string()),
      medium: v.optional(v.string()),
      campaign: v.optional(v.string()),
      term: v.optional(v.string()),
      content: v.optional(v.string()),
    })),
    
    // Device info
    device: v.optional(v.string()),
    browser: v.optional(v.string()),
    os: v.optional(v.string()),
    screenWidth: v.optional(v.number()),
    screenHeight: v.optional(v.number()),
    
    // Geo
    ip: v.optional(v.string()),
    country: v.optional(v.string()),
    region: v.optional(v.string()),
    city: v.optional(v.string()),
    
    // Experiment assignments (which variants they see)
    experimentAssignments: v.optional(v.any()), // { experimentId: "variant_A" }
    
    isBot: v.optional(v.boolean()),
  })
    .index("by_website", ["websiteId"])
    .index("by_anonymous", ["websiteId", "anonymousId"])
    .index("by_contact", ["contactId"])
    .index("by_fingerprint", ["websiteId", "fingerprintId"]),

  // ============================================================
  // EVENTS (analytics)
  // ============================================================
  events: defineTable({
    websiteId: v.id("websites"),
    sessionId: v.optional(v.id("sessions")),
    contactId: v.optional(v.id("contacts")),
    pageId: v.optional(v.id("pages")),
    blockId: v.optional(v.id("blocks")),
    
    type: v.union(
      v.literal("page_view"),
      v.literal("page_exit"),
      v.literal("block_view"),                 // Block entered viewport
      v.literal("block_click"),
      v.literal("form_start"),                 // Started filling form
      v.literal("form_submit"),
      v.literal("form_abandon"),
      v.literal("button_click"),
      v.literal("link_click"),
      v.literal("video_play"),
      v.literal("video_complete"),
      v.literal("scroll_depth"),               // 25%, 50%, 75%, 100%
      v.literal("popup_shown"),
      v.literal("popup_closed"),
      v.literal("popup_dismissed"),
      v.literal("sticky_bar_shown"),
      v.literal("sticky_bar_click"),
      v.literal("quiz_start"),
      v.literal("quiz_answer"),
      v.literal("quiz_complete"),
      v.literal("experiment_impression"),
      v.literal("conversion"),                 // Custom goal
      v.literal("revenue"),                    // Revenue event
      v.literal("custom"),                     // Custom event
    ),
    
    // Event metadata
    metadata: v.optional(v.any()),
    // Examples:
    // page_view:    { url: "/summer-sale", title: "Summer Sale" }
    // form_submit:  { formId: "...", fields: { email: "...", name: "..." } }
    // scroll_depth: { percent: 75 }
    // button_click: { buttonText: "Buy Now", targetUrl: "/checkout" }
    // quiz_answer:  { questionId: "q1", answerId: "a2", answerText: "..." }
    // conversion:   { goalId: "purchase", value: 99.99 }
    // experiment_impression: { experimentId: "...", variantId: "...", variantName: "B" }
    
    // Attribution
    url: v.optional(v.string()),
    referrer: v.optional(v.string()),
    
    timestamp: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_website_type", ["websiteId", "type"])
    .index("by_page", ["pageId"])
    .index("by_session", ["sessionId"])
    .index("by_contact", ["contactId"])
    .index("by_timestamp", ["websiteId", "timestamp"]),

  // ============================================================
  // SEGMENTS (audience definitions)
  // ============================================================
  segments: defineTable({
    websiteId: v.id("websites"),
    name: v.string(),                          // "High-Intent Visitors"
    description: v.optional(v.string()),
    
    // Rule-based definition
    rules: v.array(v.object({
      group: v.optional(v.string()),           // Rule group (AND within group, OR between groups)
      field: v.string(),                       // What to evaluate
      // Fields: "email", "country", "device", "browser", "os", "language",
      //         "utm_source", "utm_medium", "utm_campaign", "referrer",
      //         "total_visits", "total_page_views", "engagement_score",
      //         "last_seen_days_ago", "first_seen_days_ago",
      //         "tag", "custom_field.*", "quiz_result.*",
      //         "page_viewed", "form_submitted", "returning_visitor",
      //         "url_contains", "url_path"
      operator: v.string(),                    // "equals", "not_equals", "contains", "not_contains",
                                               // "starts_with", "ends_with", "gt", "lt", "gte", "lte",
                                               // "in", "not_in", "exists", "not_exists", "between"
      value: v.any(),
    })),
    
    // Evaluation
    matchType: v.union(
      v.literal("all"),                        // AND — all rules must match
      v.literal("any"),                        // OR — any rule matches
      v.literal("custom"),                     // Complex AND/OR with groups
    ),
    
    // Cached stats
    contactCount: v.optional(v.number()),
    lastEvaluatedAt: v.optional(v.number()),
    
    isSystem: v.optional(v.boolean()),         // Built-in segments
    createdAt: v.number(),
    updatedAt: v.number(),
  })
    .index("by_website", ["websiteId"]),

  // ============================================================
  // EXPERIMENTS (A/B testing)
  // ============================================================
  experiments: defineTable({
    websiteId: v.id("websites"),
    name: v.string(),                          // "Hero CTA Color Test"
    description: v.optional(v.string()),
    
    status: v.union(
      v.literal("draft"),
      v.literal("running"),
      v.literal("paused"),
      v.literal("completed"),
      v.literal("archived"),
    ),
    
    // What we're testing
    type: v.union(
      v.literal("page"),                       // Full page A/B test
      v.literal("block"),                      // Single block variant
      v.literal("redirect"),                   // URL redirect test
      v.literal("multivariate"),               // Multiple block changes
    ),
    
    // Variants
    variants: v.array(v.object({
      id: v.string(),                          // "control", "variant_b", "variant_c"
      name: v.string(),                        // "Control", "Red CTA", "Green CTA"
      weight: v.number(),                      // Traffic split (0-100, must sum to 100)
      pageId: v.optional(v.id("pages")),       // For page-level tests
      blockOverrides: v.optional(v.any()),     // For block-level tests: { blockId: { changes } }
      redirectUrl: v.optional(v.string()),     // For redirect tests
      isControl: v.boolean(),
    })),
    
    // Goal definition
    primaryGoal: v.object({
      type: v.union(
        v.literal("form_submit"),
        v.literal("button_click"),
        v.literal("page_view"),
        v.literal("custom_event"),
        v.literal("revenue"),
      ),
      targetPageId: v.optional(v.id("pages")),
      targetBlockId: v.optional(v.id("blocks")),
      eventName: v.optional(v.string()),
    }),
    secondaryGoals: v.optional(v.array(v.any())),
    
    // Targeting
    audienceSegmentId: v.optional(v.id("segments")), // Only test within segment
    urlTargeting: v.optional(v.array(v.any())),
    
    // Statistical settings
    confidenceLevel: v.optional(v.number()),   // 0.95 default
    minimumSampleSize: v.optional(v.number()), // Per variant
    minimumRunDays: v.optional(v.number()),
    
    // Results (updated by cron)
    results: v.optional(v.object({
      totalVisitors: v.number(),
      startedAt: v.number(),
      variantResults: v.any(),                 // { variantId: { visitors, conversions, rate, confidence, improvement } }
      winner: v.optional(v.string()),          // Winning variant ID
      confidence: v.optional(v.number()),
      isSignificant: v.optional(v.boolean()),
    })),
    
    // Auto-optimization
    autoOptimize: v.optional(v.boolean()),     // Bayesian bandit mode
    autoEndOnSignificance: v.optional(v.boolean()),
    
    startedAt: v.optional(v.number()),
    endedAt: v.optional(v.number()),
    createdAt: v.number(),
    updatedAt: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_status", ["websiteId", "status"]),

  // ============================================================
  // CAMPAIGNS (multi-step funnels)
  // ============================================================
  campaigns: defineTable({
    websiteId: v.id("websites"),
    name: v.string(),                          // "Black Friday Funnel"
    description: v.optional(v.string()),
    status: v.union(
      v.literal("draft"),
      v.literal("active"),
      v.literal("paused"),
      v.literal("completed"),
      v.literal("archived"),
    ),
    
    // Funnel steps
    steps: v.array(v.object({
      id: v.string(),                          // Step ID
      name: v.string(),                        // "Opt-In", "Sales Page", "Checkout"
      type: v.union(
        v.literal("landing_page"),
        v.literal("popup"),
        v.literal("email"),
        v.literal("sms"),
        v.literal("delay"),
        v.literal("condition"),
        v.literal("webhook"),
      ),
      pageId: v.optional(v.id("pages")),       // For page steps
      order: v.number(),
      
      // Conditional routing
      conditions: v.optional(v.array(v.object({
        field: v.string(),
        operator: v.string(),
        value: v.any(),
        nextStepId: v.string(),
      }))),
      defaultNextStepId: v.optional(v.string()),
      
      // Delay settings
      delayMinutes: v.optional(v.number()),
      
      // Email/SMS settings
      emailSubject: v.optional(v.string()),
      emailBody: v.optional(v.string()),
      smsBody: v.optional(v.string()),
      
      // Webhook
      webhookUrl: v.optional(v.string()),
      webhookMethod: v.optional(v.string()),
    })),
    
    // Campaign-level targeting
    audienceSegmentId: v.optional(v.id("segments")),
    
    // Stats
    stats: v.optional(v.object({
      totalEntries: v.number(),
      completions: v.number(),
      dropoffs: v.any(),                       // { stepId: count }
      revenue: v.optional(v.number()),
    })),
    
    // GHL Integration
    ghlPipelineId: v.optional(v.string()),
    ghlPipelineStages: v.optional(v.any()),    // Map step → GHL stage
    
    createdAt: v.number(),
    updatedAt: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_status", ["websiteId", "status"]),

  // ============================================================
  // FORM SUBMISSIONS
  // ============================================================
  formSubmissions: defineTable({
    websiteId: v.id("websites"),
    pageId: v.id("pages"),
    blockId: v.optional(v.id("blocks")),
    contactId: v.optional(v.id("contacts")),
    sessionId: v.optional(v.id("sessions")),
    
    // Form data
    fields: v.any(),                           // { email: "...", name: "...", phone: "..." }
    
    // Context
    url: v.optional(v.string()),
    referrer: v.optional(v.string()),
    utm: v.optional(v.any()),
    
    // Processing
    processed: v.boolean(),                    // Integrations triggered
    integrationResults: v.optional(v.any()),   // { ghl: { success: true }, mailchimp: { success: true } }
    
    createdAt: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_page", ["pageId"])
    .index("by_contact", ["contactId"]),

  // ============================================================
  // CUSTOM FIELDS (contact field definitions)
  // ============================================================
  customFieldDefinitions: defineTable({
    websiteId: v.id("websites"),
    name: v.string(),                          // "Industry"
    key: v.string(),                           // "industry"
    type: v.union(
      v.literal("text"),
      v.literal("number"),
      v.literal("email"),
      v.literal("phone"),
      v.literal("url"),
      v.literal("date"),
      v.literal("select"),
      v.literal("multi_select"),
      v.literal("checkbox"),
      v.literal("textarea"),
    ),
    options: v.optional(v.array(v.string())),  // For select/multi_select
    required: v.optional(v.boolean()),
    defaultValue: v.optional(v.string()),
    isSystem: v.optional(v.boolean()),
    order: v.number(),
    createdAt: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_key", ["websiteId", "key"]),

  // ============================================================
  // INTEGRATIONS
  // ============================================================
  integrations: defineTable({
    websiteId: v.id("websites"),
    provider: v.string(),                      // "ghl", "mailchimp", "klaviyo", "zapier", "webhook", "shopify", "stripe", "hubspot", "activecampaign", "drip", "convertkit", "sendgrid", "slack"
    name: v.string(),                          // Display name
    status: v.union(
      v.literal("active"),
      v.literal("inactive"),
      v.literal("error"),
    ),
    config: v.any(),                           // Provider-specific config
    // GHL:        { apiKey, locationId, pipelineId }
    // Mailchimp:  { apiKey, listId, tags }
    // Klaviyo:    { apiKey, listId }
    // Zapier:     { webhookUrl }
    // Webhook:    { url, method, headers }
    // Shopify:    { shopDomain, accessToken }
    // Stripe:     { secretKey, webhookSecret }
    
    // Mapping
    fieldMapping: v.optional(v.any()),         // { ourField: theirField }
    
    lastSyncAt: v.optional(v.number()),
    lastError: v.optional(v.string()),
    createdAt: v.number(),
    updatedAt: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_provider", ["websiteId", "provider"]),

  // ============================================================
  // ANALYTICS ROLLUPS (pre-aggregated stats)
  // ============================================================
  analyticsDaily: defineTable({
    websiteId: v.id("websites"),
    pageId: v.optional(v.id("pages")),
    date: v.string(),                          // "2026-05-18"
    
    views: v.number(),
    uniqueVisitors: v.number(),
    submissions: v.number(),
    conversions: v.number(),
    revenue: v.optional(v.number()),
    bounceRate: v.optional(v.number()),
    avgTimeOnPage: v.optional(v.number()),
    avgScrollDepth: v.optional(v.number()),
    
    // By source
    sourceBreakdown: v.optional(v.any()),      // { "google": { views: 100 }, "facebook": { views: 50 } }
    deviceBreakdown: v.optional(v.any()),      // { "desktop": { views: 200 }, "mobile": { views: 100 } }
    countryBreakdown: v.optional(v.any()),
  })
    .index("by_website_date", ["websiteId", "date"])
    .index("by_page_date", ["pageId", "date"]),

  // ============================================================
  // MEDIA LIBRARY
  // ============================================================
  media: defineTable({
    websiteId: v.id("websites"),
    filename: v.string(),
    mimeType: v.string(),
    size: v.number(),
    storageId: v.id("_storage"),               // Convex file storage
    url: v.optional(v.string()),               // Public URL after upload
    width: v.optional(v.number()),
    height: v.optional(v.number()),
    alt: v.optional(v.string()),
    folder: v.optional(v.string()),
    createdAt: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_folder", ["websiteId", "folder"]),

  // ============================================================
  // DOMAINS
  // ============================================================
  domains: defineTable({
    websiteId: v.id("websites"),
    domain: v.string(),                        // "fgs.wantthisoffer.com"
    type: v.union(
      v.literal("primary"),
      v.literal("alias"),
    ),
    sslStatus: v.union(
      v.literal("pending"),
      v.literal("active"),
      v.literal("error"),
    ),
    vercelProjectId: v.optional(v.string()),
    dnsVerified: v.boolean(),
    createdAt: v.number(),
  })
    .index("by_website", ["websiteId"])
    .index("by_domain", ["domain"]),
});
```

### 2.2 Relationship Map

```
websites ──┬── pages ──── blocks (nested tree)
           │      │
           │      ├── formSubmissions
           │      └── (linked to experiments, campaigns)
           │
           ├── contacts ──── sessions
           │      │              │
           │      └── events ────┘
           │
           ├── segments (rules → evaluate against contacts)
           │
           ├── experiments (variants → pages)
           │
           ├── campaigns (steps → pages)
           │
           ├── templates
           │
           ├── integrations
           │
           ├── customFieldDefinitions
           │
           ├── analyticsDaily (rollup)
           │
           ├── media
           │
           └── domains
```

---

## 3. BUILDER ENGINE — COMPONENT ARCHITECTURE

### 3.1 Builder State Management

The builder uses a React context provider pattern with immutable state updates and undo/redo history.

```typescript
// builder/BuilderContext.tsx

interface BuilderState {
  // Current page being edited
  page: Page;
  
  // Block tree (ordered, nested)
  blocks: Block[];
  
  // Selection
  selectedBlockId: string | null;
  hoveredBlockId: string | null;
  
  // Editing mode
  mode: "edit" | "preview" | "code";
  
  // Viewport
  viewport: "desktop" | "tablet" | "mobile";
  viewportWidth: number;
  
  // Panels
  leftPanel: "blocks" | "layers" | "pages" | null;
  rightPanel: "properties" | "styles" | "animations" | "visibility" | null;
  
  // Drag state
  isDragging: boolean;
  dragSource: { blockId: string; type: string } | null;
  dropTarget: { parentId: string | null; index: number } | null;
  
  // History
  undoStack: BuilderState[];
  redoStack: BuilderState[];
  
  // Dirty flag
  hasUnsavedChanges: boolean;
  lastSavedAt: number | null;
  autoSaveTimer: NodeJS.Timeout | null;
}

type BuilderAction =
  | { type: "SELECT_BLOCK"; blockId: string | null }
  | { type: "HOVER_BLOCK"; blockId: string | null }
  | { type: "ADD_BLOCK"; blockType: string; parentId: string | null; index: number }
  | { type: "MOVE_BLOCK"; blockId: string; targetParentId: string | null; targetIndex: number }
  | { type: "DELETE_BLOCK"; blockId: string }
  | { type: "DUPLICATE_BLOCK"; blockId: string }
  | { type: "UPDATE_BLOCK_CONTENT"; blockId: string; content: Partial<BlockContent> }
  | { type: "UPDATE_BLOCK_STYLE"; blockId: string; style: Partial<BlockStyle> }
  | { type: "UPDATE_BLOCK_MOBILE_STYLE"; blockId: string; style: Partial<BlockStyle> }
  | { type: "UPDATE_BLOCK_VISIBILITY"; blockId: string; rules: VisibilityRule[] }
  | { type: "UPDATE_PAGE_SETTINGS"; settings: Partial<PageSettings> }
  | { type: "SET_VIEWPORT"; viewport: "desktop" | "tablet" | "mobile" }
  | { type: "SET_MODE"; mode: "edit" | "preview" | "code" }
  | { type: "TOGGLE_LEFT_PANEL"; panel: string }
  | { type: "TOGGLE_RIGHT_PANEL"; panel: string }
  | { type: "UNDO" }
  | { type: "REDO" }
  | { type: "SAVE"; timestamp: number }
  | { type: "LOAD_PAGE"; page: Page; blocks: Block[] };

// Reducer handles all state transitions immutably
function builderReducer(state: BuilderState, action: BuilderAction): BuilderState {
  // Push current state to undo stack before mutation (for undoable actions)
  const undoable = ["ADD_BLOCK", "MOVE_BLOCK", "DELETE_BLOCK", "DUPLICATE_BLOCK", 
                     "UPDATE_BLOCK_CONTENT", "UPDATE_BLOCK_STYLE", "UPDATE_PAGE_SETTINGS"];
  
  let newState = { ...state };
  
  if (undoable.includes(action.type)) {
    newState.undoStack = [...state.undoStack.slice(-49), state]; // Keep 50 undo levels
    newState.redoStack = [];
    newState.hasUnsavedChanges = true;
  }
  
  switch (action.type) {
    case "ADD_BLOCK":
      return addBlock(newState, action);
    case "MOVE_BLOCK":
      return moveBlock(newState, action);
    case "DELETE_BLOCK":
      return deleteBlock(newState, action);
    // ... etc
  }
}
```

### 3.2 Builder Layout

```
┌─────────────────────────────────────────────────────────────────┐
│ TOOLBAR                                                         │
│ [←] [→] [💾 Save] [👁 Preview] [📱 Desktop ▾] ... [🚀 Publish]│
├──────────┬──────────────────────────────────┬───────────────────┤
│ LEFT     │                                  │ RIGHT             │
│ PANEL    │         CANVAS                   │ PANEL             │
│ 240px    │                                  │ 320px             │
│          │  ┌──────────────────────────┐    │                   │
│ [Blocks] │  │     Page Content         │    │ [Properties]      │
│ [Layers] │  │                          │    │ [Style]           │
│ [Pages]  │  │  Block 1 (Hero)          │    │ [Animation]       │
│          │  │  ┌──────────────────┐    │    │ [Visibility]      │
│ ─────    │  │  │ Selected block   │    │    │                   │
│ BLOCK    │  │  │ (blue outline)   │    │    │ ─── Properties ── │
│ LIBRARY  │  │  └──────────────────┘    │    │                   │
│          │  │                          │    │ Heading: [____]   │
│ Layout   │  │  Block 2 (Text)          │    │ Subheading: [__]  │
│  Section │  │  Block 3 (Image)         │    │ CTA Text: [____]  │
│  Columns │  │  Block 4 (Form)          │    │ CTA URL: [____]   │
│  Grid    │  │                          │    │ CTA Style: [▾]    │
│          │  │                          │    │                   │
│ Content  │  │  ── Drop zone ──         │    │ Background: [🎨]  │
│  Text    │  │                          │    │ Overlay: [slider]  │
│  Image   │  │                          │    │                   │
│  Video   │  └──────────────────────────┘    │ ─── Style ─────── │
│  Button  │                                  │                   │
│  Divider │                                  │ Margin: [T][R][B] │
│  Spacer  │                                  │ Padding: [T][R][B]│
│          │                                  │ Background: [🎨]  │
│ Forms    │                                  │ Border: [____]    │
│  Form    │                                  │ Shadow: [▾]       │
│  Quiz    │                                  │ Radius: [slider]  │
│  Survey  │                                  │                   │
│          │                                  │                   │
│ Social   │                                  │                   │
│  Testi.  │                                  │                   │
│  Logos   │                                  │                   │
│  Proof   │                                  │                   │
│          │                                  │                   │
│ Commerce │                                  │                   │
│  Pricing │                                  │                   │
│  Product │                                  │                   │
│  Timer   │                                  │                   │
│          │                                  │                   │
│ Advanced │                                  │                   │
│  HTML    │                                  │                   │
│  Code    │                                  │                   │
│  Embed   │                                  │                   │
└──────────┴──────────────────────────────────┴───────────────────┘
```

### 3.3 Drag and Drop System

```typescript
// builder/dnd/DragContext.tsx

import { DndContext, DragOverlay, closestCenter, PointerSensor, useSensor } from "@dnd-kit/core";
import { SortableContext, verticalListSortingStrategy } from "@dnd-kit/sortable";

interface DragData {
  type: "block-library" | "existing-block";
  blockType?: string;      // For new blocks from library
  blockId?: string;        // For moving existing blocks
  parentId?: string | null;
}

// Drop zones appear between existing blocks
// Blue line indicator shows where block will be inserted
// Nested drop zones for column children

// Block library items are draggable with type="block-library"
// Existing blocks in canvas are sortable with type="existing-block"

// On drag end:
// 1. If source is "block-library" → dispatch ADD_BLOCK at drop position
// 2. If source is "existing-block" → dispatch MOVE_BLOCK to new position
// 3. Update block order values
// 4. If dropping into ColumnsBlock → set parentBlockId
```

### 3.4 Auto-Save System

```typescript
// Auto-save triggers:
// 1. Debounced 2 seconds after last change
// 2. On viewport switch
// 3. On panel toggle
// 4. Before publish
// 5. Before browser unload (beforeunload event)

// Save flow:
// 1. Serialize current block tree to Convex mutations
// 2. Batch update all changed blocks
// 3. Update page.updatedAt + page.currentVersion
// 4. Show "Saved" indicator in toolbar (green checkmark, fades after 2s)
// 5. Reset hasUnsavedChanges flag
```

