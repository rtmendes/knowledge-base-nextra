## 8. PUBLISHED PAGE RENDERER

### 8.1 Architecture — Islands + Pre-Rendering

Published pages must load in <100ms. Architecture:

1. **Build-time**: When user clicks "Publish", server-side renders full HTML + CSS
2. **Serve-time**: Static HTML served from edge CDN (Vercel/Cloudflare)
3. **Hydration**: Only interactive blocks (forms, quizzes, countdown, popups) get JS hydration islands
4. **Tracking**: Lightweight tracking script (~3KB gzipped) loads async

```typescript
// convex/publishing.ts

export const publishPage = mutation({
  args: { pageId: v.id("pages") },
  handler: async (ctx, args) => {
    const page = await ctx.db.get(args.pageId);
    const blocks = await ctx.db
      .query("blocks")
      .withIndex("by_page_version", q => q.eq("pageId", args.pageId).eq("version", page.currentVersion))
      .collect();
    
    // Build block tree (flat → nested)
    const blockTree = buildBlockTree(blocks);
    
    // Generate HTML
    const html = renderPageHtml(page, blockTree);
    
    // Generate scoped CSS
    const css = generatePageCss(page, blockTree);
    
    // Extract fonts used
    const fonts = extractUsedFonts(page, blockTree);
    
    // Generate full document
    const fullHtml = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  ${page.settings.metaTitle ? `<title>${escapeHtml(page.settings.metaTitle)}</title>` : ''}
  ${page.settings.metaDescription ? `<meta name="description" content="${escapeHtml(page.settings.metaDescription)}">` : ''}
  ${page.settings.ogImage ? `<meta property="og:image" content="${page.settings.ogImage}">` : ''}
  ${page.settings.noIndex ? '<meta name="robots" content="noindex">' : ''}
  ${page.settings.canonicalUrl ? `<link rel="canonical" href="${page.settings.canonicalUrl}">` : ''}
  ${fonts.map(f => `<link href="https://fonts.googleapis.com/css2?family=${encodeURIComponent(f)}:wght@400;500;600;700&display=swap" rel="stylesheet">`).join('\n  ')}
  <style>${css}</style>
  ${page.settings.headCode || ''}
</head>
<body>
  ${page.settings.bodyStartCode || ''}
  <div id="oe-page" data-page-id="${args.pageId}">
    ${html}
  </div>
  ${page.settings.bodyEndCode || ''}
  
  <!-- Tracking script (async, non-blocking) -->
  <script async src="/tracking.js" data-website="${page.websiteId}" data-page="${args.pageId}"></script>
  
  <!-- Hydration islands for interactive blocks -->
  ${generateHydrationScript(blockTree)}
</body>
</html>`;
    
    // Store published version
    await ctx.db.patch(args.pageId, {
      status: "published",
      publishedVersion: page.currentVersion,
      publishedAt: Date.now(),
      publishedHtml: fullHtml,
      publishedCss: css,
    });
    
    return { success: true, url: getPageUrl(page) };
  },
});
```

### 8.2 Block Rendering (Server-Side)

```typescript
function renderBlockHtml(block: Block, children: string = ""): string {
  const style = blockStyleToCss(block.style);
  const mobileStyle = block.mobileStyle ? `@media(max-width:767px){#b-${block._id}{${blockStyleToCss(block.mobileStyle)}}}` : "";
  const animation = block.style?.animation && block.style.animation !== "none" 
    ? `data-animation="${block.style.animation}" data-delay="${block.style.animationDelay || 0}"`
    : "";
  const visibility = block.visibilityRules?.length 
    ? `data-visibility='${JSON.stringify(block.visibilityRules)}'`
    : "";
  
  const wrapper = `<div id="b-${block._id}" class="oe-block oe-${block.type}" style="${style}" ${animation} ${visibility}>`;
  
  switch (block.type) {
    case "hero":
      return renderHeroHtml(block, wrapper);
    case "text":
      return `${wrapper}${serializeSlateToHtml(block.content.richText)}</div>`;
    case "image":
      return `${wrapper}<img src="${block.content.src}" alt="${escapeHtml(block.content.alt)}" width="${block.content.width}" height="${block.content.height}" loading="lazy" ${block.content.link ? `onclick="window.open('${block.content.link}')"` : ""} /></div>`;
    case "button":
      return renderButtonHtml(block, wrapper);
    case "video":
      return renderVideoHtml(block, wrapper);
    case "form":
      // Form gets hydration island
      return `${wrapper}<div data-hydrate="form" data-props='${JSON.stringify(block.content)}'></div></div>`;
    case "quiz":
      return `${wrapper}<div data-hydrate="quiz" data-props='${JSON.stringify(block.content)}'></div></div>`;
    case "countdown":
      return `${wrapper}<div data-hydrate="countdown" data-props='${JSON.stringify(block.content)}'></div></div>`;
    case "columns":
      return renderColumnsHtml(block, children);
    case "pricing":
      return renderPricingHtml(block, wrapper);
    case "testimonial":
      return renderTestimonialHtml(block, wrapper);
    case "faq":
      // FAQ accordion needs hydration for expand/collapse
      return `${wrapper}<div data-hydrate="faq" data-props='${JSON.stringify(block.content)}'></div></div>`;
    // ... all other block types
    default:
      return `${wrapper}${children}</div>`;
  }
}
```

### 8.3 Hydration Islands (Client-Side)

```typescript
// published/hydration.ts — Lightweight Preact components for interactive blocks
// Total bundle: ~15KB gzipped (Preact 3KB + form 4KB + countdown 2KB + quiz 5KB + faq 1KB)

import { h, render } from "preact";
import { useState, useEffect } from "preact/hooks";

// Auto-hydrate all interactive blocks
document.querySelectorAll("[data-hydrate]").forEach(el => {
  const type = el.dataset.hydrate;
  const props = JSON.parse(el.dataset.props || "{}");
  
  switch (type) {
    case "form":
      render(h(FormIsland, props), el);
      break;
    case "quiz":
      render(h(QuizIsland, props), el);
      break;
    case "countdown":
      render(h(CountdownIsland, props), el);
      break;
    case "faq":
      render(h(FAQIsland, props), el);
      break;
  }
});

// Form Island — handles validation, submission, integration triggers
function FormIsland(props: FormBlockContent) {
  const [values, setValues] = useState({});
  const [errors, setErrors] = useState({});
  const [submitting, setSubmitting] = useState(false);
  const [submitted, setSubmitted] = useState(false);
  
  async function handleSubmit(e: Event) {
    e.preventDefault();
    
    // Client-side validation
    const newErrors = validateForm(props.fields, values);
    if (Object.keys(newErrors).length > 0) {
      setErrors(newErrors);
      return;
    }
    
    setSubmitting(true);
    
    try {
      // Submit to Convex API
      const response = await fetch("/api/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          pageId: window.__OE_PAGE_ID__,
          blockId: props.blockId,
          fields: values,
          sessionId: window.__OE_SESSION_ID__,
          url: window.location.href,
          referrer: document.referrer,
          utm: window.__OE_UTM__,
        }),
      });
      
      if (response.ok) {
        setSubmitted(true);
        
        // Track conversion
        window.__OE_TRACK__("form_submit", { formId: props.blockId, fields: Object.keys(values) });
        
        // Handle success action
        switch (props.successAction) {
          case "redirect":
            window.location.href = props.successRedirectUrl;
            break;
          case "popup":
            // Trigger popup page
            break;
          case "next_step":
            // Campaign step advancement
            break;
        }
      }
    } catch (err) {
      setErrors({ _form: props.errorMessage || "Something went wrong. Please try again." });
    } finally {
      setSubmitting(false);
    }
  }
  
  if (submitted && props.successAction === "message") {
    return h("div", { class: "oe-form-success" }, props.successMessage);
  }
  
  return h("form", { onSubmit: handleSubmit, class: `oe-form oe-form-${props.layout}` },
    props.fields.map(field => renderFormField(field, values, errors, setValues)),
    h("button", {
      type: "submit",
      disabled: submitting,
      class: `oe-submit oe-submit-${props.submitStyle} oe-submit-${props.submitSize}`,
      style: `background:${props.submitColor};color:${props.submitTextColor}`,
    }, submitting ? "Submitting..." : props.submitText)
  );
}
```

### 8.4 HTTP Routing for Published Pages

```typescript
// convex/http.ts

import { httpRouter } from "convex/server";
import { httpAction } from "./_generated/server";

const http = httpRouter();

// Serve published landing pages
http.route({
  path: "/p/:slug",
  method: "GET",
  handler: httpAction(async (ctx, request) => {
    const slug = request.pathParams.slug;
    const host = request.headers.get("host");
    
    // Look up domain → website
    const domain = await ctx.runQuery(internal.domains.getByDomain, { domain: host });
    const websiteId = domain?.websiteId;
    
    // Find page by slug
    const page = await ctx.runQuery(internal.pages.getBySlug, { websiteId, slug });
    
    if (!page || page.status !== "published") {
      return new Response("Not Found", { status: 404 });
    }
    
    // Check A/B test assignment
    const experimentHtml = await ctx.runAction(internal.experiments.getVariantHtml, {
      pageId: page._id,
      sessionId: getSessionId(request),
    });
    
    const html = experimentHtml || page.publishedHtml;
    
    // Apply personalization (dynamic field replacement)
    const personalizedHtml = await ctx.runAction(internal.identity.personalizePage, {
      html,
      sessionId: getSessionId(request),
      contactId: getContactId(request),
    });
    
    return new Response(personalizedHtml, {
      headers: {
        "Content-Type": "text/html; charset=utf-8",
        "Cache-Control": "public, max-age=60, stale-while-revalidate=300",
        "X-Page-Id": page._id,
      },
    });
  }),
});

// Tracking pixel / event ingestion
http.route({
  path: "/api/track",
  method: "POST",
  handler: httpAction(async (ctx, request) => {
    const body = await request.json();
    await ctx.runMutation(internal.analytics.ingestEvent, body);
    return new Response("ok", { status: 200 });
  }),
});

// Form submission endpoint
http.route({
  path: "/api/submit",
  method: "POST",
  handler: httpAction(async (ctx, request) => {
    const body = await request.json();
    const result = await ctx.runMutation(internal.forms.handleSubmission, body);
    return new Response(JSON.stringify(result), {
      status: result.success ? 200 : 400,
      headers: { "Content-Type": "application/json" },
    });
  }),
});

export default http;
```

