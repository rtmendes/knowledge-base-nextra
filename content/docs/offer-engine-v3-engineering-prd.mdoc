## 10. PERSONALIZATION & AUDIENCE ENGINE

### 10.1 Segment Rule Evaluation

```typescript
// convex/segments.ts

// Evaluate a contact against a segment's rules
export function evaluateSegment(contact: Contact, session: Session, segment: Segment): boolean {
  const rules = segment.rules;
  
  if (segment.matchType === "all") {
    return rules.every(rule => evaluateRule(contact, session, rule));
  } else if (segment.matchType === "any") {
    return rules.some(rule => evaluateRule(contact, session, rule));
  } else {
    // Custom: group rules by group field, AND within group, OR between groups
    const groups = new Map<string, Rule[]>();
    for (const rule of rules) {
      const group = rule.group || "default";
      if (!groups.has(group)) groups.set(group, []);
      groups.get(group)!.push(rule);
    }
    
    return Array.from(groups.values()).some(groupRules =>
      groupRules.every(rule => evaluateRule(contact, session, rule))
    );
  }
}

function evaluateRule(contact: Contact, session: Session, rule: Rule): boolean {
  const value = getFieldValue(contact, session, rule.field);
  
  switch (rule.operator) {
    case "equals": return value == rule.value;
    case "not_equals": return value != rule.value;
    case "contains": return String(value).toLowerCase().includes(String(rule.value).toLowerCase());
    case "not_contains": return !String(value).toLowerCase().includes(String(rule.value).toLowerCase());
    case "starts_with": return String(value).startsWith(String(rule.value));
    case "ends_with": return String(value).endsWith(String(rule.value));
    case "gt": return Number(value) > Number(rule.value);
    case "lt": return Number(value) < Number(rule.value);
    case "gte": return Number(value) >= Number(rule.value);
    case "lte": return Number(value) <= Number(rule.value);
    case "in": return Array.isArray(rule.value) && rule.value.includes(value);
    case "not_in": return Array.isArray(rule.value) && !rule.value.includes(value);
    case "exists": return value !== null && value !== undefined && value !== "";
    case "not_exists": return value === null || value === undefined || value === "";
    case "between": return Number(value) >= rule.value[0] && Number(value) <= rule.value[1];
    case "regex": return new RegExp(rule.value).test(String(value));
    default: return false;
  }
}

function getFieldValue(contact: Contact, session: Session, field: string): any {
  // Direct contact fields
  if (field === "email") return contact?.email;
  if (field === "country") return contact?.country || session?.country;
  if (field === "city") return contact?.city || session?.city;
  if (field === "device") return contact?.device || session?.device;
  if (field === "browser") return contact?.browser || session?.browser;
  if (field === "os") return contact?.os || session?.os;
  if (field === "language") return contact?.language;
  
  // UTM fields
  if (field === "utm_source") return session?.utm?.source || contact?.lastTouchUtm?.source;
  if (field === "utm_medium") return session?.utm?.medium || contact?.lastTouchUtm?.medium;
  if (field === "utm_campaign") return session?.utm?.campaign || contact?.lastTouchUtm?.campaign;
  
  // Behavioral
  if (field === "total_visits") return contact?.totalVisits || 0;
  if (field === "total_page_views") return contact?.totalPageViews || 0;
  if (field === "engagement_score") return contact?.engagementScore || 0;
  if (field === "returning_visitor") return (contact?.totalVisits || 0) > 1;
  
  // Time-based
  if (field === "last_seen_days_ago") {
    return contact?.lastSeenAt ? Math.floor((Date.now() - contact.lastSeenAt) / 86400000) : null;
  }
  if (field === "first_seen_days_ago") {
    return contact?.firstSeenAt ? Math.floor((Date.now() - contact.firstSeenAt) / 86400000) : null;
  }
  
  // Tags
  if (field === "tag") return contact?.tags || [];
  
  // Custom fields
  if (field.startsWith("custom.")) {
    const key = field.replace("custom.", "");
    return contact?.customFields?.[key];
  }
  
  // Quiz results
  if (field.startsWith("quiz_result.")) {
    const quizId = field.replace("quiz_result.", "");
    return contact?.quizResponses?.[quizId]?.result;
  }
  
  // URL context (from session)
  if (field === "url_contains") return session?.currentUrl;
  if (field === "url_path") return new URL(session?.currentUrl || "").pathname;
  if (field === "referrer") return session?.referrer;
  
  return null;
}
```

### 10.2 Dynamic Content Personalization

```typescript
// On published page, blocks with visibilityRules are shown/hidden based on visitor
// Dynamic fields in rich text ({{first_name}}) are replaced with contact data

// Client-side personalization script (loaded on published pages)
// /tracking.js includes this:

async function personalizeContent() {
  const sessionId = getOrCreateSessionId();
  
  // Fetch personalization data from API
  const response = await fetch("/api/personalize", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      pageId: window.__OE_PAGE_ID__,
      sessionId,
      url: window.location.href,
      referrer: document.referrer,
      utm: parseUtmParams(),
      device: detectDevice(),
      screenWidth: window.innerWidth,
    }),
  });
  
  const data = await response.json();
  // data = { contact: {...}, segments: [...], visibilityMap: { blockId: true/false }, dynamicFields: { first_name: "Sarah" } }
  
  // Apply visibility rules
  for (const [blockId, visible] of Object.entries(data.visibilityMap)) {
    const el = document.getElementById(`b-${blockId}`);
    if (el) el.style.display = visible ? "" : "none";
  }
  
  // Replace dynamic fields
  document.querySelectorAll("[data-dynamic-field]").forEach(el => {
    const field = el.dataset.dynamicField;
    const fallback = el.dataset.fallback || "";
    el.textContent = data.dynamicFields[field] || fallback;
  });
}
```

