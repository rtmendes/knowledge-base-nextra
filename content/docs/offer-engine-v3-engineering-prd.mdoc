## 7. TEMPLATE SYSTEM

### 7.1 Template Storage & Cloning

```typescript
// convex/templates.ts

// Creating a template from a page
export const createFromPage = mutation({
  args: {
    pageId: v.id("pages"),
    name: v.string(),
    category: v.string(),
    subcategory: v.optional(v.string()),
    tags: v.optional(v.array(v.string())),
  },
  handler: async (ctx, args) => {
    const page = await ctx.db.get(args.pageId);
    const blocks = await ctx.db
      .query("blocks")
      .withIndex("by_page_version", q => q.eq("pageId", args.pageId).eq("version", page.currentVersion))
      .collect();
    
    // Deep clone page settings + blocks (strip IDs, keep structure)
    const templateBlocks = blocks.map(b => ({
      type: b.type,
      order: b.order,
      content: b.content,
      style: b.style,
      mobileStyle: b.mobileStyle,
      tabletStyle: b.tabletStyle,
      visibilityRules: b.visibilityRules,
      // Preserve parent-child relationships via temp IDs
      _tempId: b._id.toString(),
      _tempParentId: b.parentBlockId?.toString() || null,
    }));
    
    // Take screenshot for thumbnail
    const thumbnail = await generateThumbnail(page);
    
    return ctx.db.insert("templates", {
      name: args.name,
      category: args.category,
      subcategory: args.subcategory || null,
      tags: args.tags || [],
      thumbnail,
      pageSettings: page.settings,
      blocks: templateBlocks,
      isSystem: false,
      isPublic: false,
      usageCount: 0,
      createdAt: Date.now(),
      updatedAt: Date.now(),
    });
  },
});

// Applying a template to a new page
export const applyTemplate = mutation({
  args: {
    templateId: v.id("templates"),
    websiteId: v.id("websites"),
    pageName: v.string(),
    pageType: v.string(),
  },
  handler: async (ctx, args) => {
    const template = await ctx.db.get(args.templateId);
    
    // Create new page with template settings
    const pageId = await ctx.db.insert("pages", {
      websiteId: args.websiteId,
      name: args.pageName,
      slug: slugify(args.pageName),
      type: args.pageType,
      status: "draft",
      currentVersion: 1,
      settings: template.pageSettings,
      templateId: args.templateId,
      templateName: template.name,
      createdAt: Date.now(),
      updatedAt: Date.now(),
    });
    
    // Clone blocks with new IDs, preserving parent-child
    const idMap = new Map();
    for (const block of template.blocks) {
      const newId = await ctx.db.insert("blocks", {
        pageId,
        parentBlockId: block._tempParentId ? idMap.get(block._tempParentId) : null,
        type: block.type,
        order: block.order,
        version: 1,
        content: block.content,
        style: block.style,
        mobileStyle: block.mobileStyle,
        tabletStyle: block.tabletStyle,
        visibilityRules: block.visibilityRules,
        createdAt: Date.now(),
        updatedAt: Date.now(),
      });
      idMap.set(block._tempId, newId);
    }
    
    // Increment template usage
    await ctx.db.patch(args.templateId, { usageCount: (template.usageCount || 0) + 1 });
    
    return pageId;
  },
});
```

