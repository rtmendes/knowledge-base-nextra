  "--button-text-transform": { label: "Button Case", type: "string", default: "none" },
  "--button-padding-x": { label: "Button Pad X", type: "size", default: "1.5rem" },
  "--button-padding-y": { label: "Button Pad Y", type: "size", default: "0.75rem" },
  "--button-border-radius": { label: "Button Radius", type: "size", default: "8px" },
  
  // ── Forms ──
  "--input-background": { label: "Input BG", type: "color", default: "#FFFFFF" },
  "--input-border": { label: "Input Border", type: "color", default: "#D1D5DB" },
  "--input-border-focus": { label: "Input Focus", type: "color", default: "#3B82F6" },
  "--input-radius": { label: "Input Radius", type: "size", default: "6px" },
  "--input-padding": { label: "Input Padding", type: "size", default: "0.75rem 1rem" },
  "--input-font-size": { label: "Input Font", type: "size", default: "1rem" },
  
  // ── Animation ──
  "--transition-speed": { label: "Transition", type: "string", default: "0.2s" },
  "--animation-duration": { label: "Animation", type: "string", default: "0.5s" },
};

