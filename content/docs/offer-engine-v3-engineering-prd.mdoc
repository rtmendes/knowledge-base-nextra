## 5. RICH TEXT EDITOR — SLATE.JS IMPLEMENTATION

### 5.1 Slate Configuration

```typescript
// lib/slate/slateConfig.ts

import { createEditor, Editor, Transforms, Text } from "slate";
import { withReact } from "slate-react";
import { withHistory } from "slate-history";

// Custom element types
type CustomElement =
  | { type: "paragraph"; children: CustomText[]; align?: "left" | "center" | "right" | "justify" }
  | { type: "heading-1"; children: CustomText[]; align?: string }
  | { type: "heading-2"; children: CustomText[]; align?: string }
  | { type: "heading-3"; children: CustomText[]; align?: string }
  | { type: "heading-4"; children: CustomText[]; align?: string }
  | { type: "bulleted-list"; children: CustomElement[] }
  | { type: "numbered-list"; children: CustomElement[] }
  | { type: "list-item"; children: CustomText[] }
  | { type: "blockquote"; children: CustomText[] }
  | { type: "code-block"; children: CustomText[]; language?: string }
  | { type: "link"; url: string; children: CustomText[] }
  | { type: "image"; src: string; alt: string; width: number; children: CustomText[] }
  | { type: "divider"; children: CustomText[] }
  | { type: "dynamic-field"; field: string; fallback: string; children: CustomText[] };

// Text leaf formatting
interface CustomText {
  text: string;
  bold?: boolean;
  italic?: boolean;
  underline?: boolean;
  strikethrough?: boolean;
  code?: boolean;
  color?: string;
  backgroundColor?: string;
  fontSize?: string;                           // "14px", "2rem"
  fontFamily?: string;
  lineHeight?: string;
  letterSpacing?: string;
  superscript?: boolean;
  subscript?: boolean;
}

// Toolbar buttons
const TOOLBAR_GROUPS = [
  // Text style
  ["bold", "italic", "underline", "strikethrough", "code"],
  // Headings
  ["heading-1", "heading-2", "heading-3", "heading-4", "paragraph"],
  // Alignment
  ["align-left", "align-center", "align-right", "align-justify"],
  // Lists
  ["bulleted-list", "numbered-list"],
  // Links & media
  ["link", "image"],
  // Advanced
  ["blockquote", "code-block", "divider"],
  // Colors
  ["text-color", "background-color"],
  // Font
  ["font-family", "font-size", "line-height"],
  // Dynamic
  ["dynamic-field"],                           // Insert {{first_name}}, {{company}}, etc.
  // Clear
  ["clear-formatting"],
];

// Serialize Slate JSON → HTML (for published pages)
function serializeToHtml(nodes: CustomElement[]): string {
  return nodes.map(node => {
    if (Text.isText(node)) {
      let html = escapeHtml(node.text);
      if (node.bold) html = `<strong>${html}</strong>`;
      if (node.italic) html = `<em>${html}</em>`;
      if (node.underline) html = `<u>${html}</u>`;
      if (node.strikethrough) html = `<s>${html}</s>`;
      if (node.code) html = `<code>${html}</code>`;
      if (node.color) html = `<span style="color:${node.color}">${html}</span>`;
      if (node.backgroundColor) html = `<span style="background-color:${node.backgroundColor}">${html}</span>`;
      if (node.fontSize) html = `<span style="font-size:${node.fontSize}">${html}</span>`;
      if (node.fontFamily) html = `<span style="font-family:${node.fontFamily}">${html}</span>`;
      return html;
    }
    
    const children = node.children.map(c => serializeToHtml([c])).join("");
    const align = node.align ? ` style="text-align:${node.align}"` : "";
    
    switch (node.type) {
      case "paragraph": return `<p${align}>${children}</p>`;
      case "heading-1": return `<h1${align}>${children}</h1>`;
      case "heading-2": return `<h2${align}>${children}</h2>`;
      case "heading-3": return `<h3${align}>${children}</h3>`;
      case "heading-4": return `<h4${align}>${children}</h4>`;
      case "bulleted-list": return `<ul>${children}</ul>`;
      case "numbered-list": return `<ol>${children}</ol>`;
      case "list-item": return `<li>${children}</li>`;
      case "blockquote": return `<blockquote>${children}</blockquote>`;
      case "link": return `<a href="${node.url}" target="_blank" rel="noopener">${children}</a>`;
      case "image": return `<img src="${node.src}" alt="${node.alt}" width="${node.width}" />`;
      case "divider": return `<hr />`;
      case "dynamic-field": return `<span data-dynamic-field="${node.field}" data-fallback="${node.fallback}">{{${node.field}}}</span>`;
      default: return children;
    }
  }).join("");
}
```

