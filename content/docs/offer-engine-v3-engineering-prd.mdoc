// Available dynamic fields for insertion into any text
const DYNAMIC_FIELDS = [
  { key: "first_name", label: "First Name", fallback: "there" },
  { key: "last_name", label: "Last Name", fallback: "" },
  { key: "email", label: "Email", fallback: "" },
  { key: "company", label: "Company", fallback: "your company" },
  { key: "city", label: "City", fallback: "" },
  { key: "country", label: "Country", fallback: "" },
  { key: "utm_source", label: "UTM Source", fallback: "" },
  { key: "utm_campaign", label: "UTM Campaign", fallback: "" },
  { key: "referrer", label: "Referrer", fallback: "" },
  { key: "quiz_result", label: "Quiz Result", fallback: "" },
  // Custom fields added dynamically
];

// On published page, dynamic fields are replaced with contact data:
// "Hey {{first_name}}, welcome back!" → "Hey Sarah, welcome back!"
// If contact unknown: "Hey there, welcome back!" (fallback)
