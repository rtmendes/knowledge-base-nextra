## 12. ANALYTICS PIPELINE

### 12.1 Event Ingestion

```typescript
// convex/analytics.ts

// Batch event ingestion (from tracking script)
export const ingestBatch = httpAction(async (ctx, request) => {
  const events = await request.json();
  
  for (const event of events) {
    // Validate
    if (!event.websiteId || !event.type || !event.timestamp) continue;
    
    // Find/create session
    let sessionId = null;
    if (event.sessionId) {
      const session = await ctx.runQuery(internal.sessions.getByAnonymousId, {
        websiteId: event.websiteId,
        anonymousId: event.sessionId,
      });
      sessionId = session?._id;
    }
    
    // Store event
    await ctx.runMutation(internal.events.create, {
      websiteId: event.websiteId,
      sessionId,
      contactId: null, // Will be linked when identity resolves
      pageId: event.pageId || null,
      blockId: event.blockId || null,
      type: event.type,
      metadata: event.metadata,
      url: event.url,
      referrer: event.referrer,
      timestamp: event.timestamp,
    });
    
    // Update session activity
    if (sessionId) {
      await ctx.runMutation(internal.sessions.updateActivity, {
        sessionId,
        timestamp: event.timestamp,
        pageView: event.type === "page_view",
      });
    }
  }
  
  return new Response("ok");
});
```

### 12.2 Analytics Rollup Cron

```typescript
// Runs daily at 2 AM — aggregates events into analyticsDaily
export const rollupDailyAnalytics = internalMutation({
  handler: async (ctx) => {
    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    const dateStr = yesterday.toISOString().split("T")[0];
    
    const websites = await ctx.db.query("websites").collect();
    
    for (const website of websites) {
      const startTs = new Date(dateStr).getTime();
      const endTs = startTs + 86400000;
      
      // Get all events for this website/day
      const events = await ctx.db
        .query("events")
        .withIndex("by_timestamp", q => 
          q.eq("websiteId", website._id).gte("timestamp", startTs).lt("timestamp", endTs)
        )
        .collect();
      
      const pageViews = events.filter(e => e.type === "page_view");
      const uniqueSessions = new Set(events.map(e => e.sessionId).filter(Boolean));
      const submissions = events.filter(e => e.type === "form_submit");
      const conversions = events.filter(e => e.type === "conversion");
      const revenue = events.filter(e => e.type === "revenue").reduce((s, e) => s + (e.metadata?.value || 0), 0);
      
      // Overall rollup
      await ctx.db.insert("analyticsDaily", {
        websiteId: website._id,
        date: dateStr,
        views: pageViews.length,
        uniqueVisitors: uniqueSessions.size,
        submissions: submissions.length,
        conversions: conversions.length,
        revenue: revenue || undefined,
        sourceBreakdown: groupBy(events, e => extractSource(e)),
        deviceBreakdown: groupBy(events, e => e.metadata?.device || "unknown"),
      });
      
      // Per-page rollups
      const pageGroups = groupBy(pageViews, e => e.pageId);
      for (const [pageId, pageEvents] of Object.entries(pageGroups)) {
        if (!pageId) continue;
        const pageSessions = new Set(pageEvents.map(e => e.sessionId).filter(Boolean));
        const pageSubs = submissions.filter(e => e.pageId === pageId);
        
        await ctx.db.insert("analyticsDaily", {
          websiteId: website._id,
          pageId,
          date: dateStr,
          views: pageEvents.length,
          uniqueVisitors: pageSessions.size,
          submissions: pageSubs.length,
          conversions: conversions.filter(e => e.pageId === pageId).length,
        });
      }
    }
  },
});
```

### 12.3 Analytics Dashboard Components

```typescript
// Insights page layout:
// ┌─────────────────────────────────────────────────┐
// │ Date Range: [Last 7 days ▾] [Custom Range]      │
// ├──────┬──────┬──────┬──────┬──────┬─────────────┤
// │Views │Unique│Subs  │Conv  │Rate  │Revenue      │
// │12,450│8,920 │342   │189   │2.12% │$18,900      │
// │+12%  │+8%   │+15%  │+23%  │+0.2% │+$2,100      │
// ├──────┴──────┴──────┴──────┴──────┴─────────────┤
// │ [Line chart: Views + Conversions over time]     │
// ├────────────────────┬───────────────────────────┤
// │ Top Pages          │ Traffic Sources            │
// │ 1. /summer-sale    │ ● Google: 45%             │
// │ 2. /quiz           │ ● Facebook: 30%           │
// │ 3. /webinar        │ ● Direct: 15%             │
// │ 4. /checkout       │ ● Email: 10%              │
// ├────────────────────┼───────────────────────────┤
// │ Device Breakdown   │ Geography                  │
// │ Desktop: 65%       │ US: 72%                    │
// │ Mobile: 30%        │ UK: 12%                    │
// │ Tablet: 5%         │ CA: 8%                     │
// └────────────────────┴───────────────────────────┘
```

