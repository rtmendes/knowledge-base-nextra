      {
        "type": "paragraph",
        "children": [
          {
            "type": "text",
            "text": "Voice Profile Extraction Prompt: 'Analyze these writing samples and extract: (1) average sentence length, (2) favorite transition phrases, (3) humor style, (4) most-used power words, (5) emotional register. Return as JSON with examples from the text.'"
          }
        ]
      },
      {
        "type": "paragraph",
        "children": [
          {
            "type": "text",
            "text": "Content Generation Prompt: 'Using the attached voice profile, write a [format] about [topic] for [platform]. Match the vocabulary, tone, and sentence rhythm from the profile. Do not use words in the banned list. End with a CTA consistent with the profile style.'"
          }
        ]
