                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Fear of failing checkride \u2014 extremely high emotional and financial stakes"
                  }
