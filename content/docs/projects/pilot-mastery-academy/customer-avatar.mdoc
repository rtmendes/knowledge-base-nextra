              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Active in aviation communities (AOPA, Reddit r/flying, PilotEdge forums)"
