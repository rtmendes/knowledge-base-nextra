    "children": [
      {
        "type": "heading",
        "level": 1,
        "children": [
          {
            "type": "text",
            "text": "Product Requirements Document \u2014 Pilot Mastery Academy"
          }
        ]
      },
      {
        "type": "heading",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "Problem Statement"
          }
        ]
      },
      {
        "type": "paragraph",
        "children": [
          {
            "type": "text",
            "text": "Aspiring pilots face a fragmented, expensive, and often inefficient path to obtaining their certifications and building flight hours. Ground school materials are outdated, exam prep is scattered across multiple paid resources, and career mentorship from working pilots is nearly impossible to access at scale. Pilot Mastery Academy consolidates exam prep, AI-powered study tools, and direct mentorship from professional pilots into one affordable platform."
          }
        ]
      },
      {
        "type": "heading",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "Goals"
          }
        ]
      },
      {
        "type": "unordered-list",
        "children": [
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Reduce the average time to pass the FAA written exams by 40%"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Provide AI-powered oral exam prep that simulates actual DPE questioning styles"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Offer career mentorship from ATP-rated pilots in major airlines and charter operations"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Build the go-to community for student pilots through PPL, IFR, CPL, and ATP"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "heading",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "Core Features"
          }
        ]
      },
      {
        "type": "unordered-list",
        "children": [
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Adaptive Study Engine: identifies weak areas from practice tests, focuses review there"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "AI Oral Exam Simulator: Claude-powered DPE simulation with realistic question patterns"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Flight Log Analyzer: tracks student hours and milestones; alerts when requirements are close"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Mentorship Marketplace: book 1-hour calls with ATP-rated pilots by specialty"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Checkride Prep Kits: scenario-based prep packages for each FAA checkride"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
