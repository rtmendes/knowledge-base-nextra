{
  "root": {
    "type": "root",
    "children": [
      {"type":"heading","level":1,"children":[{"type":"text","text":"Product Requirements Document — PopeBot / InsightProfit"}]},
      {"type":"heading","level":2,"children":[{"type":"text","text":"Problem Statement"}]},
      {"type":"paragraph","children":[{"type":"text","text":"Online entrepreneurs, course creators, and digital product sellers lack a centralized AI-powered system to analyze their revenue data, identify profit leaks, and automate decision-making. They spend hours manually reviewing dashboards, writing content, and chasing customer insights — time that should be spent on high-leverage activities. PopeBot serves as the AI brain of InsightProfit: an always-on profit intelligence assistant that turns raw business data into actionable directives."}]},
      {"type":"heading","level":2,"children":[{"type":"text","text":"Goals"}]},
      {"type":"unordered-list","children":[
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Deliver a conversational AI assistant (PopeBot) trained on the user's own knowledge base, revenue data, and SOPs"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Surface profit opportunities and red flags from connected data sources within seconds"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Automate repetitive content, outreach, and reporting tasks so the operator stays in flow"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Create a scalable KB infrastructure that compounds in value as more projects feed into it"}]}]}
      ]},
      {"type":"heading","level":2,"children":[{"type":"text","text":"Core Features"}]},
      {"type":"unordered-list","children":[
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"PopeBot Chat Interface — Claude-powered Q&A against the full knowledge base"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Revenue Intelligence Dashboard — connects to Stripe, ThriveCart, PayPal; flags anomalies"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Automated SOP Execution — bot triggers multi-step workflows from natural-language commands"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Content Generation Pipeline — email sequences, VSL scripts, ad copy on demand"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Nextra Knowledge Base — structured docs site as the single source of truth"}]}]}
      ]},
      {"type":"heading","level":2,"children":[{"type":"text","text":"Success Metrics"}]},
      {"type":"unordered-list","children":[
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Operator saves 10+ hours/week on research and reporting within 30 days"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"PopeBot answers 90%+ of business queries accurately from KB context"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"At least 3 automated workflows running without manual intervention by day 60"}]}]},
        {"type":"list-item","children":[{"type":"paragraph","children":[{"type":"text","text":"Revenue intelligence alerts identify one actionable opportunity per week"}]}]}
      ]}
    ]
  }
}
