      },
      {
        "type": "heading",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "Brand Personality"
          }
        ]
      },
      {
        "type": "paragraph",
        "children": [
          {
            "type": "text",
            "text": "InsightProfit is the strategic partner \u2014 authoritative, data-driven, results-obsessed. PopeBot is the trusted advisor \u2014 direct, a little irreverent, deeply competent. Together they project the archetype of the 'brilliant friend who happens to know business.'"
          }
        ]
      },
      {
        "type": "heading",
        "level": 2,
        "children": [
          {
            "type": "text",
            "text": "Voice & Tone"
          }
        ]
      },
      {
        "type": "unordered-list",
        "children": [
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Direct and confident \u2014 no hedging, no filler"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Data-backed \u2014 every claim pairs with a number or example"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Slightly provocative \u2014 challenges conventional wisdom"
                  }
                ]
              }
            ]
          },
          {
            "type": "list-item",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "type": "text",
                    "text": "Warm but not soft \u2014 cares about your success, not your comfort"
                  }
                ]
              }
            ]
          }
        ]
      },
