## 5. BRAND KIT EXTRACTOR

### `convex/roast/brandKitExtractor.ts`

Auto-extracts brand assets from a URL (mirrors AdRoast's "Marinate from your website" feature).

```typescript
"use node";
import { action } from "../_generated/server";
import { v } from "convex/values";
import Anthropic from "@anthropic-ai/sdk";

export const extractBrandKit = action({
  args: {
    websiteUrl: v.string(),
  },
  handler: async (ctx, args) => {
    // 1. Fetch the website HTML
    const response = await fetch(args.websiteUrl, {
      headers: { "User-Agent": "Mozilla/5.0 (compatible; BrandExtractor/1.0)" }
    });
    const html = await response.text();

    // 2. Extract meta tags, stylesheets, favicon
    const metaTitle = html.match(/<title>(.*?)<\/title>/i)?.[1] || "";
    const metaDescription = html.match(/<meta[^>]*name="description"[^>]*content="([^"]*)">/i)?.[1] || "";
    const favicon = html.match(/<link[^>]*rel="(?:icon|shortcut icon)"[^>]*href="([^"]*)">/i)?.[1] || "";

    // 3. Extract inline CSS colors
    const colorMatches = html.match(/#[0-9a-fA-F]{3,8}/g) || [];
    const rgbMatches = html.match(/rgb\([^)]+\)/g) || [];

    // 4. Extract Google Fonts
    const fontMatches = html.match(/fonts\.googleapis\.com\/css2?\?family=([^"&]+)/g) || [];
    const fontFamilies = fontMatches.map(m => decodeURIComponent(m.split("family=")[1]?.split("&")[0] || ""));

    // 5. Use Claude to analyze and identify brand elements
    const anthropic = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });

    const analysisResponse = await anthropic.messages.create({
      model: "claude-sonnet-4-20250514",
      max_tokens: 2048,
      messages: [{
        role: "user",
        content: `Analyze this website's brand identity from its HTML. Extract:
1. Brand name
2. Primary color (hex)
3. Secondary color (hex)
4. Accent color (hex)
5. Background color (hex)
6. Heading font family
7. Body font family
8. Brand voice/tone (3-5 adjectives)
9. Industry
10. Target audience

Website: ${args.websiteUrl}
Title: ${metaTitle}
Description: ${metaDescription}
Colors found: ${[...new Set(colorMatches)].slice(0, 20).join(", ")}
Fonts found: ${fontFamilies.join(", ")}

HTML excerpt (first 5000 chars):
${html.substring(0, 5000)}

Return JSON: { "name", "primaryColor", "secondaryColor", "accentColor", "backgroundColor", "fontHeading", "fontBody", "voiceTone", "industry", "targetAudience" }`
      }]
    });

    const responseText = analysisResponse.content[0].type === "text" ? analysisResponse.content[0].text : "";
    const jsonMatch = responseText.match(/\{[\s\S]*\}/);
    if (!jsonMatch) throw new Error("Failed to extract brand kit");
    const brandData = JSON.parse(jsonMatch[0]);

    // 6. Resolve logo URL
    let logoUrl = "";
    if (favicon) {
      logoUrl = favicon.startsWith("http") ? favicon : new URL(favicon, args.websiteUrl).href;
    }

    // 7. Create brand kit record
    const brandKitId = await ctx.runMutation(/* insert brand kit */, {
      name: brandData.name || metaTitle,
      websiteUrl: args.websiteUrl,
      logoUrl,
      primaryColor: brandData.primaryColor || "#000000",
      secondaryColor: brandData.secondaryColor || null,
      accentColor: brandData.accentColor || null,
      backgroundColor: brandData.backgroundColor || "#FFFFFF",
      fontHeading: brandData.fontHeading || null,
      fontBody: brandData.fontBody || null,
      voiceTone: brandData.voiceTone || null,
      industry: brandData.industry || null,
      targetAudience: brandData.targetAudience || null,
      isDefault: false,
      createdAt: Date.now(),
      updatedAt: Date.now(),
    });

    return { brandKitId, brandData };
  },
});
```

