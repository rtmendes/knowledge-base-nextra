## 4. AI ANALYSIS ENGINE

### 4.1 Main Analysis Action — `convex/roast/analyzeCreative.ts`

This is the core AI action. It uses Claude Vision (claude-sonnet-4-20250514) to analyze the creative against the scoring framework.

```typescript
"use node";
import { action } from "../_generated/server";
import { v } from "convex/values";
import Anthropic from "@anthropic-ai/sdk";
import { SCORING_CATEGORIES, scoreToGrade } from "./scoringFramework";

// === SYSTEM PROMPT FOR CREATIVE ANALYSIS ===
const ANALYSIS_SYSTEM_PROMPT = `You are an elite Meta Ads creative strategist with 10+ years of experience managing $1B+ in ad spend across hundreds of ecommerce and lead gen accounts. You've seen tens of thousands of ad creatives and know exactly what works and what burns budget.

Your job is to score ad creatives BEFORE they go live on Meta — catching weak spots, identifying strengths, and providing specific, actionable fixes.

You score creatives against 10 categories (10 points each, 100 total):
1. Hook Strength (10pts) — Does it stop the scroll in <0.5s?
2. Visual Hierarchy (10pts) — Is the eye guided correctly?
3. CTA Clarity (10pts) — Is the desired action obvious?
4. Audience Alignment (10pts) — Does it speak to the target?
5. Scroll-Stop Power (10pts) — How disruptive is it in the feed?
6. Text & Copy Overlay (10pts) — Readable, concise, persuasive?
7. Brand Consistency (10pts) — Reinforces brand recognition?
8. Emotional Trigger (10pts) — Triggers action-driving emotion?
9. Platform Fit (10pts) — Optimized for Meta formats?
10. Offer Clarity (10pts) — Is the value proposition obvious?

SCORING RULES:
- Be brutally honest. Most ads score 40-70. Only exceptional creatives hit 85+.
- Every point must be justified with a specific observation.
- Don't inflate scores to be nice. A 45 is common and useful feedback.
- When in lazy mode (no context provided), infer the likely industry, audience, and goal from the creative itself.
- For winners_benchmark mode, compare the new creative against the uploaded winners and score relative to that performance standard.
- For competitor_spy mode, score the creative AND compare it against the competitor's creative approach.

OUTPUT FORMAT (JSON):
{
  "overallScore": <number 0-100>,
  "verdict": "<1-2 sentence summary — what's working and what's not>",
  "categoryScores": {
    "hookStrength": { "score": <0-10>, "feedback": "<specific observation>" },
    "visualHierarchy": { "score": <0-10>, "feedback": "<specific observation>" },
    "ctaClarity": { "score": <0-10>, "feedback": "<specific observation>" },
    "audienceAlignment": { "score": <0-10>, "feedback": "<specific observation>" },
    "scrollStopPower": { "score": <0-10>, "feedback": "<specific observation>" },
    "textOverlay": { "score": <0-10>, "feedback": "<specific observation>" },
    "brandConsistency": { "score": <0-10>, "feedback": "<specific observation>" },
    "emotionalTrigger": { "score": <0-10>, "feedback": "<specific observation>" },
    "platformFit": { "score": <0-10>, "feedback": "<specific observation>" },
    "offerClarity": { "score": <0-10>, "feedback": "<specific observation>" }
  },
  "strengths": ["<strength 1>", "<strength 2>", ...],
  "weakSpots": [
    {
      "issue": "<specific problem>",
      "severity": "critical|major|minor",
      "fix": "<specific actionable fix>",
      "category": "<which scoring category>"
    }
  ],
  "recommendations": ["<top 3-5 specific next steps>"],
  "inferredContext": {  // Only in lazy mode
    "likelyIndustry": "<inferred>",
    "likelyGoal": "<inferred>",
    "likelyAudience": "<inferred>"
  }
}`;

// === MODE-SPECIFIC PROMPTS ===
const MODE_PROMPTS = {
  standard: `Analyze this ad creative using the full scoring framework. The advertiser has provided context about their industry, goal, and product.`,

  winners_benchmark: `The advertiser has uploaded their best-performing creatives as reference. Analyze the NEW creative (the main upload) against their winning creative playbook. Identify:
1. What patterns from the winners are present in the new creative
2. What patterns from the winners are MISSING
3. How the new creative differs in approach
4. Whether the differences are improvements or regressions
Score relative to the winners' standard — if the winners are strong, a 70 means "below your own bar."`,

  competitor_spy: `The advertiser wants to compare their creative against a competitor's ads. Analyze the main creative AND note:
1. What the competitor is doing that this creative doesn't
2. What this creative does BETTER than the competitor
3. Specific elements to steal/adapt from the competitor's approach
4. Areas where the creative falls short of the competitive standard
Include a "competitorComparison" section in your analysis.`,

  meta_performance: `This creative is ALREADY RUNNING on Meta with real performance data provided. Use the actual metrics to validate your visual analysis:
- If CTR is low (<1%), focus scoring on hook strength and scroll-stop power
- If CPA is high, focus on offer clarity and CTA
- If ROAS is low, focus on audience alignment and emotional trigger
Correlate what you SEE with what the DATA shows.`,

  lazy: `No context was provided. Analyze this creative purely on visual merit. Infer the likely industry, goal, target audience, and product from what you see. Include your inferences in the "inferredContext" field. Score everything — don't penalize for "not matching audience" since you're inferring the audience.`,
};

export const analyzeCreative = action({
  args: {
    analysisId: v.id("roastAnalyses"),
  },
  handler: async (ctx, args) => {
    const startTime = Date.now();

    // 1. Fetch the analysis record
    const analysis = await ctx.runQuery(/* internal query to get analysis by ID */);
    if (!analysis) throw new Error("Analysis not found");

    // 2. Get the creative image as base64
    const imageUrl = await ctx.storage.getUrl(analysis.creativeFileId);
    const imageResponse = await fetch(imageUrl!);
    const imageBuffer = await imageResponse.arrayBuffer();
    const base64Image = Buffer.from(imageBuffer).toString("base64");
    const mediaType = analysis.creativeType === "image" ? "image/jpeg" : "image/png";

    // 3. Build the prompt based on mode
    let modePrompt = MODE_PROMPTS[analysis.mode] || MODE_PROMPTS.standard;
    if (analysis.isLazyMode) {
      modePrompt = MODE_PROMPTS.lazy;
    }

    // 4. Build context string
    let contextStr = "";
    if (!analysis.isLazyMode) {
      contextStr = `\n\nADVERTISER CONTEXT:
- Industry: ${analysis.industry || "Not specified"}
- Goal: ${analysis.goal || "Not specified"}
- Product/Offer: ${analysis.productDescription || "Not specified"}
- Target Audience: ${analysis.targetAudience || "Not specified"}
- Extra Info: ${analysis.extraProductInfo || "None"}
- Landing Page: ${analysis.landingPageUrl || "None"}`;
    }

    // 5. Handle brand kit context
    let brandContext = "";
    if (analysis.brandKitId) {
      const brandKit = await ctx.runQuery(/* get brand kit */);
      if (brandKit) {
        brandContext = `\n\nBRAND KIT:
- Brand: ${brandKit.name}
- Primary Color: ${brandKit.primaryColor}
- Secondary Color: ${brandKit.secondaryColor || "N/A"}
- Font (Heading): ${brandKit.fontHeading || "N/A"}
- Font (Body): ${brandKit.fontBody || "N/A"}
- Voice/Tone: ${brandKit.voiceTone || "N/A"}`;
      }
    }

    // 6. Handle winners benchmark mode
    let winnersContext = "";
    if (analysis.mode === "winners_benchmark" && analysis.winnerCreativeUrls?.length) {
      winnersContext = `\n\nWINNER REFERENCE CREATIVES: ${analysis.winnerCreativeUrls.length} uploaded.
Why they're winners: ${analysis.winnerExplanation || "Not explained"}`;
      // Note: Winner images should also be sent as additional image blocks
    }

    // 7. Handle competitor spy mode
    let competitorContext = "";
    if (analysis.mode === "competitor_spy") {
      competitorContext = `\n\nCOMPETITOR: ${analysis.competitorBrandName}
URL: ${analysis.competitorUrl}`;
      // Competitor ad images should also be sent as additional image blocks
    }

    // 8. Handle meta performance mode
    let metaContext = "";
    if (analysis.mode === "meta_performance" && analysis.metaPerformanceData) {
      const d = analysis.metaPerformanceData;
      metaContext = `\n\nLIVE META PERFORMANCE DATA:
- Spend: $${d.spend}
- Impressions: ${d.impressions}
- Clicks: ${d.clicks}
- CTR: ${d.ctr}%
- CPC: $${d.cpc}
- Conversions: ${d.conversions}
- CPA: $${d.cpa}
- ROAS: ${d.roas}x`;
    }

    // 9. Build message content array
    const content: any[] = [
      {
        type: "image",
        source: { type: "base64", media_type: mediaType, data: base64Image }
      },
      {
        type: "text",
        text: `${modePrompt}${contextStr}${brandContext}${winnersContext}${competitorContext}${metaContext}

Analyze this creative now. Return ONLY valid JSON matching the specified format.`
      }
    ];

    // 10. Add winner images if in winners_benchmark mode
    if (analysis.mode === "winners_benchmark" && analysis.winnerCreativeFileIds?.length) {
      for (const fileId of analysis.winnerCreativeFileIds.slice(0, 10)) {
        const winUrl = await ctx.storage.getUrl(fileId);
        if (winUrl) {
          const winResp = await fetch(winUrl);
          const winBuf = await winResp.arrayBuffer();
          content.push({
            type: "image",
            source: { type: "base64", media_type: "image/jpeg", data: Buffer.from(winBuf).toString("base64") }
          });
        }
      }
      content.push({ type: "text", text: "The images above (after the first) are the advertiser's WINNING creatives. Compare the FIRST image against these winners." });
    }

    // 11. Call Claude Vision
    const anthropic = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });
    const response = await anthropic.messages.create({
      model: "claude-sonnet-4-20250514",
      max_tokens: 4096,
      system: ANALYSIS_SYSTEM_PROMPT,
      messages: [{ role: "user", content }],
    });

    // 12. Parse response
    const responseText = response.content[0].type === "text" ? response.content[0].text : "";
    const jsonMatch = responseText.match(/\{[\s\S]*\}/);
    if (!jsonMatch) throw new Error("Failed to parse AI response");
    const result = JSON.parse(jsonMatch[0]);

    // 13. Calculate grade
    const grade = scoreToGrade(result.overallScore);

    // 14. Update the analysis record
    await ctx.runMutation(/* internal mutation to update analysis */, {
      id: args.analysisId,
      overallScore: result.overallScore,
      scoreGrade: grade,
      categoryScores: {
        hookStrength: { score: result.categoryScores.hookStrength.score, maxScore: 10, feedback: result.categoryScores.hookStrength.feedback },
        visualHierarchy: { score: result.categoryScores.visualHierarchy.score, maxScore: 10, feedback: result.categoryScores.visualHierarchy.feedback },
        ctaClarity: { score: result.categoryScores.ctaClarity.score, maxScore: 10, feedback: result.categoryScores.ctaClarity.feedback },
        audienceAlignment: { score: result.categoryScores.audienceAlignment.score, maxScore: 10, feedback: result.categoryScores.audienceAlignment.feedback },
        scrollStopPower: { score: result.categoryScores.scrollStopPower.score, maxScore: 10, feedback: result.categoryScores.scrollStopPower.feedback },
        textOverlay: { score: result.categoryScores.textOverlay.score, maxScore: 10, feedback: result.categoryScores.textOverlay.feedback },
        brandConsistency: { score: result.categoryScores.brandConsistency.score, maxScore: 10, feedback: result.categoryScores.brandConsistency.feedback },
        emotionalTrigger: { score: result.categoryScores.emotionalTrigger.score, maxScore: 10, feedback: result.categoryScores.emotionalTrigger.feedback },
        platformFit: { score: result.categoryScores.platformFit.score, maxScore: 10, feedback: result.categoryScores.platformFit.feedback },
        offerClarity: { score: result.categoryScores.offerClarity.score, maxScore: 10, feedback: result.categoryScores.offerClarity.feedback },
      },
      verdict: result.verdict,
      strengths: result.strengths,
      weakSpots: result.weakSpots,
      recommendations: result.recommendations,
      competitorComparison: result.competitorComparison || null,
      status: "complete",
      analysisTimeMs: Date.now() - startTime,
      modelUsed: "claude-sonnet-4-20250514",
      updatedAt: Date.now(),
    });

    return { success: true, score: result.overallScore, grade };
  },
});
```

### 4.2 Variant Generation Action — `convex/roast/generateVariants.ts`

Generates 3 improved variants using GPT Image 2 (via OpenAI API).

```typescript
"use node";
import { action } from "../_generated/server";
import { v } from "convex/values";
import OpenAI from "openai";

const VARIANT_SYSTEM_PROMPT = `You are an elite ad creative director. Given an original ad creative and its scoring analysis, generate an improved version that specifically addresses the identified weak spots while preserving the strengths.

For each variant, make DIFFERENT improvements:
- Variant A: Focus on fixing the #1 and #2 highest-severity weak spots
- Variant B: Focus on maximizing scroll-stop power and hook strength
- Variant C: Focus on offer clarity and CTA optimization

RULES:
- Keep the core product/offer the same
- Keep brand colors and fonts if a brand kit is provided
- Make the improvements VISIBLE and MEANINGFUL — not subtle tweaks
- Each variant should look distinctly different from the original
- Predict the lift % based on how much each fix typically improves performance`;

export const generateVariants = action({
  args: {
    analysisId: v.id("roastAnalyses"),
  },
  handler: async (ctx, args) => {
    // 1. Fetch analysis with scores and weak spots
    const analysis = await ctx.runQuery(/* get analysis */);
    if (!analysis || !analysis.weakSpots) throw new Error("Analysis not found or not scored");

    // 2. Get original image
    const imageUrl = await ctx.storage.getUrl(analysis.creativeFileId);

    // 3. Build improvement prompts for each variant
    const variants = [
      {
        label: "A" as const,
        focus: "Fix top weak spots",
        prompt: buildVariantPrompt(analysis, "A"),
      },
      {
        label: "B" as const,
        focus: "Maximize scroll-stop power",
        prompt: buildVariantPrompt(analysis, "B"),
      },
      {
        label: "C" as const,
        focus: "Optimize offer + CTA",
        prompt: buildVariantPrompt(analysis, "C"),
      },
    ];

    // 4. Generate all 3 variants via GPT Image 2
    const openai = new OpenAI({ apiKey: process.env.OPENAI_API_KEY });

    for (const variant of variants) {
      const startTime = Date.now();

      // Use GPT Image 2 for generation
      const response = await openai.images.edit({
        model: "gpt-image-1",  // or dall-e-3 as fallback
        image: await fetch(imageUrl!).then(r => r.arrayBuffer()),
        prompt: variant.prompt,
        n: 1,
        size: "1024x1024",
      });

      const generatedUrl = response.data[0]?.url || response.data[0]?.b64_json;
      if (!generatedUrl) continue;

      // 5. Upload to Convex storage
      const imgResponse = await fetch(generatedUrl);
      const imgBlob = await imgResponse.blob();
      const storageId = await ctx.storage.store(imgBlob);
      const storedUrl = await ctx.storage.getUrl(storageId);

      // 6. Calculate predicted lift based on weak spots fixed
      const predictedLift = calculatePredictedLift(analysis, variant.label);

      // 7. Save variant
      await ctx.runMutation(/* insert variant */, {
        analysisId: args.analysisId,
        variantLabel: variant.label,
        imageUrl: storedUrl!,
        imageFileId: storageId,
        prompt: variant.prompt,
        predictedLift,
        changes: getVariantChanges(analysis, variant.label),
        modelUsed: "gpt-image-2",
        generationTimeMs: Date.now() - startTime,
        createdAt: Date.now(),
      });
    }

    // 8. Update analysis with best lift
    const bestLift = Math.max(...variants.map((_, i) =>
      calculatePredictedLift(analysis, ["A", "B", "C"][i] as any)
    ));
    await ctx.runMutation(/* update analysis */, {
      id: args.analysisId,
      variantsGenerated: true,
      predictedLift: bestLift,
      updatedAt: Date.now(),
    });
  },
});

function buildVariantPrompt(analysis: any, variant: "A" | "B" | "C"): string {
  const weakSpots = analysis.weakSpots || [];
  const brandKit = analysis.brandKit; // if available

  let focusAreas = "";
  switch (variant) {
    case "A":
      // Fix top 2 highest severity weak spots
      const topIssues = weakSpots
        .sort((a: any, b: any) => severityRank(b.severity) - severityRank(a.severity))
        .slice(0, 2);
      focusAreas = topIssues.map((w: any) => `FIX: ${w.issue} → ${w.fix}`).join("\n");
      break;
    case "B":
      focusAreas = `MAXIMIZE scroll-stopping power:
- Make the visual MORE disruptive, bolder colors, sharper contrast
- Strengthen the hook — make it impossible to scroll past
- Add pattern interrupt elements
- Increase visual dimensionality`;
      break;
    case "C":
      focusAreas = `OPTIMIZE the offer and CTA:
- Make the value proposition crystal clear in <1 second
- Make CTA text larger, more action-oriented, more urgent
- Show the product benefit more prominently
- Add price/discount if applicable`;
      break;
  }

  let brandInstructions = "";
  if (brandKit) {
    brandInstructions = `\nBRAND CONSTRAINTS:
- Primary color: ${brandKit.primaryColor}
- Logo placement: keep existing
- Font style: ${brandKit.fontHeading || "keep similar"}`;
  }

  return `Improve this ad creative for Meta Ads. This is the SAME product/offer — make it perform BETTER, not different.

ORIGINAL SCORE: ${analysis.overallScore}/100

IMPROVEMENTS TO MAKE:
${focusAreas}
${brandInstructions}

Keep the same product, same offer, same general layout. Make targeted improvements that would increase click-through rate and conversions.`;
}

function severityRank(severity: string): number {
  return { critical: 3, major: 2, minor: 1 }[severity] || 0;
}

function calculatePredictedLift(analysis: any, variant: string): number {
  // Estimate lift based on which weak spots each variant fixes
  // Critical fix = +15-25%, Major fix = +8-15%, Minor fix = +3-8%
  const weakSpots = analysis.weakSpots || [];
  let lift = 0;

  switch (variant) {
    case "A": {
      const topIssues = weakSpots
        .sort((a: any, b: any) => severityRank(b.severity) - severityRank(a.severity))
        .slice(0, 2);
      for (const issue of topIssues) {
        if (issue.severity === "critical") lift += 15 + Math.random() * 10;
        else if (issue.severity === "major") lift += 8 + Math.random() * 7;
        else lift += 3 + Math.random() * 5;
      }
      break;
    }
    case "B": {
      const hookScore = analysis.categoryScores?.hookStrength?.score || 5;
      const scrollScore = analysis.categoryScores?.scrollStopPower?.score || 5;
      lift = (20 - hookScore - scrollScore) * 2 + Math.random() * 8;
      break;
    }
    case "C": {
      const ctaScore = analysis.categoryScores?.ctaClarity?.score || 5;
      const offerScore = analysis.categoryScores?.offerClarity?.score || 5;
      lift = (20 - ctaScore - offerScore) * 2 + Math.random() * 8;
      break;
    }
  }

  return Math.round(Math.max(5, Math.min(65, lift)));
}

function getVariantChanges(analysis: any, variant: string): string[] {
  const weakSpots = analysis.weakSpots || [];
  switch (variant) {
    case "A":
      return weakSpots
        .sort((a: any, b: any) => severityRank(b.severity) - severityRank(a.severity))
        .slice(0, 2)
        .map((w: any) => w.fix);
    case "B":
      return [
        "Enhanced visual contrast and scroll-stop power",
        "Strengthened hook with bolder composition",
        "Added pattern interrupt elements",
      ];
    case "C":
      return [
        "Optimized CTA size, color, and urgency language",
        "Clarified value proposition visibility",
        "Improved offer hierarchy and pricing display",
      ];
    default:
      return [];
  }
}
```

