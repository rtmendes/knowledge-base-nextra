## 6. COMPETITOR CREATIVE PULL

### `convex/roast/competitorPull.ts`

Pulls competitor ad creatives via Meta Ad Library API.

```typescript
"use node";
import { action } from "../_generated/server";
import { v } from "convex/values";

const META_AD_LIBRARY_API = "https://graph.facebook.com/v21.0/ads_archive";

export const pullCompetitorAds = action({
  args: {
    competitorName: v.string(),
    competitorUrl: v.string(),
    limit: v.optional(v.number()),
  },
  handler: async (ctx, args) => {
    const accessToken = process.env.META_ACCESS_TOKEN;
    if (!accessToken) throw new Error("META_ACCESS_TOKEN not configured");

    const limit = args.limit || 10;

    // 1. Search Meta Ad Library for the competitor
    // The Ad Library API is publicly accessible for active ads
    const searchParams = new URLSearchParams({
      access_token: accessToken,
      search_terms: args.competitorName,
      ad_reached_countries: '["US"]',
      ad_active_status: "ACTIVE",
      ad_type: "POLITICAL_AND_ISSUE_ADS", // Use ALL for commercial
      fields: "id,ad_creative_bodies,ad_creative_link_titles,ad_creative_link_descriptions,ad_snapshot_url,page_id,page_name,publisher_platforms,estimated_audience_size",
      limit: String(limit),
    });

    // Note: For commercial ads, use the Ad Library website scraping approach
    // or the official Marketing API with proper permissions

    const response = await fetch(`${META_AD_LIBRARY_API}?${searchParams}`);
    const data = await response.json();

    if (!data.data || data.data.length === 0) {
      // Fallback: scrape Ad Library website
      return await scrapeAdLibrary(ctx, args.competitorName, args.competitorUrl, limit);
    }

    // 2. Store competitor creatives
    const creatives = [];
    for (const ad of data.data.slice(0, limit)) {
      const creativeId = await ctx.runMutation(/* insert competitor creative */, {
        competitorName: args.competitorName,
        competitorUrl: args.competitorUrl,
        adLibraryId: ad.id,
        imageUrl: ad.ad_snapshot_url || "",
        adCopy: ad.ad_creative_bodies?.[0] || "",
        headline: ad.ad_creative_link_titles?.[0] || "",
        ctaText: "",
        isActive: true,
        platform: "meta",
        pulledAt: Date.now(),
      });
      creatives.push(creativeId);
    }

    return { count: creatives.length, ids: creatives };
  },
});

async function scrapeAdLibrary(ctx: any, name: string, url: string, limit: number) {
  // Fallback: Use the Ad Library website URL pattern
  // https://www.facebook.com/ads/library/?active_status=active&ad_type=all&country=US&q=BRAND_NAME
  // This requires browser automation or screenshot approach

  // For now, return instructions for manual pull
  return {
    count: 0,
    manualUrl: `https://www.facebook.com/ads/library/?active_status=active&ad_type=all&country=US&q=${encodeURIComponent(name)}`,
    note: "Auto-pull requires Meta Marketing API access. Use the manual URL to view competitor ads, then upload screenshots to the competitor creative fields.",
  };
}
```

