## 3. SCORING FRAMEWORK

### 3.1 The Rubric — `convex/roast/scoringFramework.ts`

The scoring engine evaluates creatives against 10 categories, each worth 10 points (total: 100).

```typescript
// ============================================================
// CREATIVE SCORING FRAMEWORK
// Based on $25B+ ad spend patterns + our Meta Ads methodology
// ============================================================

export const SCORING_CATEGORIES = {
  hookStrength: {
    name: "Hook Strength",
    maxScore: 10,
    description: "Does the creative stop the scroll in <0.5 seconds?",
    criteria: [
      { points: 3, check: "Visual pattern interrupt — unusual composition, bold color, unexpected element" },
      { points: 3, check: "Emotional trigger visible — curiosity gap, fear of missing out, desire, surprise" },
      { points: 2, check: "Headline/text hook is specific, not generic — numbers, questions, bold claims" },
      { points: 2, check: "First-frame impact — the creative works even as a thumbnail" },
    ],
    scoringGuide: {
      "9-10": "Instant pattern interrupt. Would stop YOUR scroll. Unique visual + emotional trigger + specific text hook.",
      "7-8": "Strong hook but one element is generic. Good visual but headline is vague, or vice versa.",
      "5-6": "Decent but forgettable. Looks like a normal ad. Needs a sharper angle or visual disruption.",
      "3-4": "Weak hook. Stock photo vibes. Generic headline. Would scroll past in 0.2s.",
      "0-2": "No hook at all. Looks like a placeholder or internal document."
    }
  },

  visualHierarchy: {
    name: "Visual Hierarchy",
    maxScore: 10,
    description: "Is the eye guided to the right elements in the right order?",
    criteria: [
      { points: 3, check: "Clear focal point — one dominant element draws the eye first" },
      { points: 2, check: "Logical reading flow — headline → product → benefit → CTA" },
      { points: 2, check: "Adequate white space — not cluttered, elements breathe" },
      { points: 2, check: "Size contrast — important elements are larger, secondary smaller" },
      { points: 1, check: "Color contrast guides attention — CTA or key text pops" },
    ]
  },

  ctaClarity: {
    name: "CTA Clarity",
    maxScore: 10,
    description: "Is the action you want the viewer to take obvious and compelling?",
    criteria: [
      { points: 3, check: "CTA is visible within the creative (not just in Meta's button)" },
      { points: 3, check: "CTA uses action language — 'Shop Now', 'Get Yours', 'Claim 40% Off'" },
      { points: 2, check: "CTA creates urgency or scarcity — limited time, exclusive, while stocks last" },
      { points: 2, check: "Only ONE clear CTA — not competing actions" },
    ]
  },

  audienceAlignment: {
    name: "Audience Alignment",
    maxScore: 10,
    description: "Does the creative speak to the target audience's identity and desires?",
    criteria: [
      { points: 3, check: "Visual representation matches target demographic" },
      { points: 3, check: "Language/tone matches audience sophistication level" },
      { points: 2, check: "Pain point or desire is audience-specific, not generic" },
      { points: 2, check: "Social proof elements match audience (testimonials, stats, authority)" },
    ]
  },

  scrollStopPower: {
    name: "Scroll-Stop Power",
    maxScore: 10,
    description: "How much visual disruption does this creative create in a crowded feed?",
    criteria: [
      { points: 3, check: "Bold, high-contrast visual that stands out in a sea of muted content" },
      { points: 3, check: "Movement or implied motion (even in statics — action poses, dynamic composition)" },
      { points: 2, check: "Curiosity-inducing — makes you NEED to read/watch more" },
      { points: 2, check: "Dimensionality — doesn't look flat. Depth, layering, or 3D elements" },
    ]
  },

  textOverlay: {
    name: "Text & Copy Overlay",
    maxScore: 10,
    description: "Is the text on the creative readable, concise, and persuasive?",
    criteria: [
      { points: 2, check: "Text covers <20% of image area (Meta's old rule, still best practice)" },
      { points: 2, check: "Font is readable at mobile size (16pt+ equivalent)" },
      { points: 2, check: "Copy is benefit-focused, not feature-focused" },
      { points: 2, check: "Maximum 2-3 lines of text — not a paragraph" },
      { points: 2, check: "Text has contrast against background (drop shadow, banner, or high contrast)" },
    ]
  },

  brandConsistency: {
    name: "Brand Consistency",
    maxScore: 10,
    description: "Does the creative reinforce brand recognition?",
    criteria: [
      { points: 3, check: "Logo visible but not dominating (bottom corner or subtle integration)" },
      { points: 3, check: "Colors match brand palette" },
      { points: 2, check: "Typography matches brand system" },
      { points: 2, check: "Overall aesthetic matches brand positioning (premium/playful/bold)" },
    ]
  },

  emotionalTrigger: {
    name: "Emotional Trigger",
    maxScore: 10,
    description: "Does the creative trigger an emotional response that drives action?",
    criteria: [
      { points: 3, check: "Primary emotion is clear — joy, fear, desire, belonging, curiosity, urgency" },
      { points: 3, check: "Before/after or transformation is implied or shown" },
      { points: 2, check: "Social proof creates FOMO or trust" },
      { points: 2, check: "Emotional hook aligns with the product benefit (not random emotion)" },
    ]
  },

  platformFit: {
    name: "Platform Fit (Meta)",
    maxScore: 10,
    description: "Is the creative optimized for Meta's ad formats and algorithm?",
    criteria: [
      { points: 2, check: "Aspect ratio is correct — 1:1 (feed), 4:5 (feed optimal), 9:16 (stories/reels)" },
      { points: 2, check: "Safe zones respected — no critical elements cut off in any placement" },
      { points: 2, check: "Works without sound (for video) — captions or visual storytelling" },
      { points: 2, check: "Looks native to platform — not overly 'designed' or 'ad-like'" },
      { points: 2, check: "Image quality is high but file size is optimized (<30MB image, <250MB video)" },
    ]
  },

  offerClarity: {
    name: "Offer Clarity",
    maxScore: 10,
    description: "Is what you're selling and why it's valuable immediately obvious?",
    criteria: [
      { points: 3, check: "Product/offer is visible and identifiable within 1 second" },
      { points: 3, check: "Value proposition is clear — why should I care? What do I get?" },
      { points: 2, check: "Price or discount is shown (if applicable to the goal)" },
      { points: 2, check: "Risk reversal present — guarantee, free shipping, easy returns" },
    ]
  },
};

// Grade mapping
export const GRADE_MAP = {
  95: "A+", 90: "A", 85: "B+", 80: "B",
  70: "C+", 60: "C", 50: "D", 0: "F"
};

export function scoreToGrade(score: number): string {
  const thresholds = [95, 90, 85, 80, 70, 60, 50, 0];
  const grades = ["A+", "A", "B+", "B", "C+", "C", "D", "F"];
  for (let i = 0; i < thresholds.length; i++) {
    if (score >= thresholds[i]) return grades[i];
  }
  return "F";
}
```

### 3.2 Score Interpretation

```
90-100 (A/A+)  → "Ready to scale. This creative has strong fundamentals."
80-89  (B/B+)  → "Good foundation. Fix the flagged weak spots before spending."
70-79  (C+)    → "Average. Needs work on 2-3 categories before testing."
60-69  (C)     → "Below average. Major rework needed. Don't spend on this."
50-59  (D)     → "Weak. Significant issues across multiple categories."
0-49   (F)     → "Don't run this. Start over with a new concept."
```

