## 3. Architecture Design

### 3.1 Extended Schema

```typescript
// === EXTENDED COURSE TABLE ===
courses: defineTable({
  // Existing fields (preserved)
  bundle: v.string(),
  courseName: v.string(),
  title: v.string(),
  creator: v.string(),
  salesPage: v.string(),
  googleDrive: v.string(),
  megaFolder: v.string(),
  price: v.string(),
  description: v.optional(v.string()),
  bundleSection: v.optional(v.string()),
  selected: v.optional(v.boolean()),
  
  // NEW: Visual fields
  thumbnailStorageId: v.optional(v.id("_storage")),
  thumbnailUrl: v.optional(v.string()),
  salesPageScreenshotId: v.optional(v.id("_storage")),
  salesPageScreenshotUrl: v.optional(v.string()),
  heroImageUrl: v.optional(v.string()),
  
  // NEW: Classification fields
  category: v.optional(v.string()),
  subcategory: v.optional(v.string()),
  tags: v.optional(v.array(v.string())),
  courseType: v.optional(v.string()),        // "video", "pdf", "community", "software", "coaching"
  difficulty: v.optional(v.string()),         // "beginner", "intermediate", "advanced"
  format: v.optional(v.string()),             // "self-paced", "live", "hybrid", "certification"
  
  // NEW: Content Intelligence
  salesCopy: v.optional(v.string()),          // Full scraped sales page text
  contentDNA: v.optional(v.string()),         // JSON: topics, skills, tools, outcomes
  aiSummary: v.optional(v.string()),          // AI-generated 2-3 sentence summary
  qualityScore: v.optional(v.number()),       // 1-10 quality rating
  
  // NEW: File Intelligence
  fileIndex: v.optional(v.string()),          // JSON: folder structure from MEGA/Drive
  totalFileSize: v.optional(v.string()),
  fileCount: v.optional(v.number()),
  hasVideo: v.optional(v.boolean()),
  hasPdf: v.optional(v.boolean()),
  hasAudio: v.optional(v.boolean()),
  
  // NEW: Status & Metadata
  status: v.optional(v.string()),             // "new", "reviewed", "indexed", "enriched"
  lastEnriched: v.optional(v.number()),
  syncedFromSheet: v.optional(v.boolean()),
  sheetTab: v.optional(v.string()),           // Which Google Sheet tab it came from
  rating: v.optional(v.number()),             // User rating 1-5
  notes: v.optional(v.string()),
})
  .index("by_bundle", ["bundle"])
  .index("by_creator", ["creator"])
  .index("by_category", ["category"])
  .index("by_status", ["status"])
  .index("by_courseType", ["courseType"])
  .searchIndex("search_courses", {
    searchField: "courseName",
    filterFields: ["bundle", "creator", "category", "courseType"],
  })
  .searchIndex("search_description", {
    searchField: "description",
    filterFields: ["bundle", "category"],
  })
  .searchIndex("search_salesCopy", {
    searchField: "salesCopy",
    filterFields: ["category"],
  })

// === NEW: COLLECTIONS TABLE ===
collections: defineTable({
  name: v.string(),
  description: v.optional(v.string()),
  color: v.optional(v.string()),             // Hex color for visual grouping
  icon: v.optional(v.string()),              // Lucide icon name
  courseIds: v.array(v.id("courses")),
  createdBy: v.optional(v.string()),
  isSmartCollection: v.optional(v.boolean()), // Auto-populating based on rules
  smartRules: v.optional(v.string()),         // JSON: filter rules for smart collections
})
  .index("by_name", ["name"])

// === NEW: AI JOBS TABLE ===
aiJobs: defineTable({
  type: v.string(),          // "categorize", "tag", "screenshot", "enrich", "generate"
  status: v.string(),        // "pending", "running", "completed", "failed"
  targetId: v.optional(v.id("courses")),
  targetIds: v.optional(v.array(v.id("courses"))),
  input: v.optional(v.string()),
  output: v.optional(v.string()),
  error: v.optional(v.string()),
  startedAt: v.optional(v.number()),
  completedAt: v.optional(v.number()),
  progress: v.optional(v.number()),          // 0-100
  totalItems: v.optional(v.number()),
  processedItems: v.optional(v.number()),
})
  .index("by_type", ["type"])
  .index("by_status", ["status"])

// === NEW: GENERATED CONTENT TABLE ===
generatedContent: defineTable({
  courseId: v.id("courses"),
  courseIds: v.optional(v.array(v.id("courses"))),
  type: v.string(),         // "lead_magnet", "email_sequence", "social_post", "landing_copy", "blog_post"
  title: v.string(),
  content: v.string(),
  metadata: v.optional(v.string()),
  createdAt: v.number(),
})
  .index("by_course", ["courseId"])
  .index("by_type", ["type"])

// === EXTENDED BUNDLES TABLE ===
bundles: defineTable({
  name: v.string(),
  courseCount: v.number(),
  hasDownloadLinks: v.boolean(),
  selected: v.optional(v.boolean()),
  description: v.optional(v.string()),
  thumbnailUrl: v.optional(v.string()),
  totalValue: v.optional(v.number()),
})
  .index("by_name", ["name"])
```

