- discountText: string

Styling:
- Background: #F0EEFF (soft purple) or brand light accent
- Cards: white, rounded-xl, p-8, shadow-sm
- Icon: 40px, brand primary color
- Title: 20px, #333, bold
- Description: 16px, #666
- CTA: same as hero CTA pattern
