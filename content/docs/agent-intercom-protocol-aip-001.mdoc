## 4. Technical Specifications

### 4.1 Supabase Schema

```sql
-- ============================================================
-- AGENT INTERCOM PROTOCOL (AIP) — SUPABASE SCHEMA
-- ============================================================
-- Run on: Supabase self-hosted (existing instance)
-- Database: PostgreSQL 15+
-- Requires: Realtime enabled on all tables below
-- ============================================================

-- Enable required extensions
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- ============================================================
-- TABLE 1: Agent Sessions (Registry + Presence)
-- ============================================================
CREATE TABLE agent_intercom_sessions (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,

    -- Identity
    agent_id VARCHAR(100) NOT NULL,         -- unique agent identifier (e.g., "creative-scorer")
    agent_name VARCHAR(200) NOT NULL,       -- human-readable name
    app_source VARCHAR(100) NOT NULL,       -- which app this agent belongs to
    instance_id VARCHAR(100),               -- for multiple instances of same agent

    -- Capabilities (what this agent can do / answer)
    capabilities TEXT[] DEFAULT '{}',       -- e.g., {"score_creative", "fatigue_detection"}
    can_answer TEXT[] DEFAULT '{}',         -- natural language descriptions of what it can answer

    -- Presence
    status VARCHAR(20) DEFAULT 'idle' CHECK (status IN (
        'idle', 'thinking', 'processing', 'waiting', 'blocked', 'offline'
    )),
    current_task TEXT,                      -- what the agent is currently working on
    heartbeat_at TIMESTAMPTZ DEFAULT NOW(),

    -- Metadata
    model VARCHAR(100),                     -- LLM model being used (if applicable)
    version VARCHAR(20),                    -- agent version
    metadata JSONB DEFAULT '{}',            -- extensible metadata

    -- Timestamps
    registered_at TIMESTAMPTZ DEFAULT NOW(),
    last_message_at TIMESTAMPTZ,
    updated_at TIMESTAMPTZ DEFAULT NOW(),

    -- Constraints
    UNIQUE(agent_id, instance_id)
);

-- Indexes for fast lookup
CREATE INDEX idx_sessions_agent_id ON agent_intercom_sessions(agent_id);
CREATE INDEX idx_sessions_app_source ON agent_intercom_sessions(app_source);
CREATE INDEX idx_sessions_status ON agent_intercom_sessions(status);
CREATE INDEX idx_sessions_heartbeat ON agent_intercom_sessions(heartbeat_at);
CREATE INDEX idx_sessions_capabilities ON agent_intercom_sessions USING GIN(capabilities);

-- Auto-cleanup: mark stale sessions (no heartbeat > 2 minutes) as offline
-- (Implemented via cron or Supabase Edge Function)

-- ============================================================
-- TABLE 2: Messages (Core Communication)
-- ============================================================
CREATE TABLE agent_intercom_messages (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,

    -- Routing
    sender_id VARCHAR(100) NOT NULL,        -- agent_id of sender
    receiver_id VARCHAR(100) NOT NULL,      -- agent_id of receiver (or "__broadcast__")
    sender_session_id UUID REFERENCES agent_intercom_sessions(id),
    receiver_session_id UUID REFERENCES agent_intercom_sessions(id),

    -- Message type
    message_type VARCHAR(20) NOT NULL CHECK (message_type IN (
        'send',         -- fire-and-forget notification
        'ask',          -- blocking question (expects reply)
        'reply',        -- response to an ask
        'broadcast'     -- sent to all agents
    )),

    -- Threading
    reply_to_message_id UUID REFERENCES agent_intercom_messages(id),
    conversation_id UUID,                   -- groups related messages

    -- Content
    payload JSONB NOT NULL,                 -- structured message content
    -- payload schema:
    -- For send/broadcast: {text: string, data?: object, attachments?: array}
    -- For ask:            {question: string, context?: object, required_fields?: string[], timeout_minutes?: number}
    -- For reply:          {answer: string, data?: object}

    -- Delivery
    expects_reply BOOLEAN DEFAULT false,
    status VARCHAR(20) DEFAULT 'sent' CHECK (status IN (
        'sent',         -- message inserted, not yet received
        'delivered',    -- receiver acknowledged receipt
        'processing',   -- receiver is working on it
        'completed',    -- fully processed (reply sent if expected)
        'expired',      -- ask timed out without reply
        'failed'        -- delivery or processing failed
    )),
    error_message TEXT,

    -- Timestamps
    created_at TIMESTAMPTZ DEFAULT NOW(),
    delivered_at TIMESTAMPTZ,
    completed_at TIMESTAMPTZ,
    expires_at TIMESTAMPTZ,                 -- for ask messages: created_at + timeout

    -- Metadata
    metadata JSONB DEFAULT '{}'
);

-- Indexes for message routing and queries
CREATE INDEX idx_messages_receiver ON agent_intercom_messages(receiver_id, status);
CREATE INDEX idx_messages_sender ON agent_intercom_messages(sender_id);
CREATE INDEX idx_messages_reply_to ON agent_intercom_messages(reply_to_message_id);
CREATE INDEX idx_messages_conversation ON agent_intercom_messages(conversation_id);
CREATE INDEX idx_messages_type_status ON agent_intercom_messages(message_type, status);
CREATE INDEX idx_messages_created ON agent_intercom_messages(created_at DESC);
CREATE INDEX idx_messages_expires ON agent_intercom_messages(expires_at) WHERE expires_at IS NOT NULL;

-- ============================================================
-- TABLE 3: Escalations (Human-in-the-Loop)
-- ============================================================
CREATE TABLE agent_intercom_escalations (
    id UUID DEFAULT uuid_generate_v4() PRIMARY KEY,

    -- Source agent
    agent_id VARCHAR(100) NOT NULL,
    agent_session_id UUID REFERENCES agent_intercom_sessions(id),

    -- Escalation tier
    tier VARCHAR(20) NOT NULL CHECK (tier IN (
        'blocking',     -- needs immediate human decision (agent waits)
        'interview',    -- needs multiple structured answers (agent waits)
        'update'        -- fire-and-forget progress notification
    )),

    -- Content
    subject TEXT NOT NULL,                  -- one-line summary
    context JSONB,                          -- background data
    questions JSONB,                        -- for interview tier:
    -- [{id: string, question: string, type: "text"|"choice"|"boolean", options?: string[]}]

    -- Response
    response JSONB,                         -- human's response
    -- For blocking: {decision: string, notes?: string}
    -- For interview: {responses: [{id: string, value: string}]}
    responded_by VARCHAR(100),              -- Slack user who responded

    -- Status
    status VARCHAR(20) DEFAULT 'pending' CHECK (status IN (
        'pending', 'notified', 'responded', 'expired', 'cancelled'
    )),

    -- Slack integration
    slack_channel VARCHAR(20),
    slack_message_ts VARCHAR(30),
    slack_thread_ts VARCHAR(30),

    -- Timing
    timeout_minutes INTEGER DEFAULT 10,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    notified_at TIMESTAMPTZ,
    responded_at TIMESTAMPTZ,
    expires_at TIMESTAMPTZ
);

CREATE INDEX idx_escalations_agent ON agent_intercom_escalations(agent_id);
CREATE INDEX idx_escalations_status ON agent_intercom_escalations(status);
CREATE INDEX idx_escalations_tier ON agent_intercom_escalations(tier, status);

-- ============================================================
-- TABLE 4: Audit Log (Full Communication History)
-- ============================================================
CREATE TABLE agent_intercom_audit_log (
    id BIGSERIAL PRIMARY KEY,
    event_type VARCHAR(30) NOT NULL,        -- register, deregister, send, ask, reply, escalate, timeout, error
    agent_id VARCHAR(100),
    target_agent_id VARCHAR(100),
    message_id UUID,
    escalation_id UUID,
    details JSONB,
    created_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX idx_audit_event ON agent_intercom_audit_log(event_type);
CREATE INDEX idx_audit_agent ON agent_intercom_audit_log(agent_id);
CREATE INDEX idx_audit_created ON agent_intercom_audit_log(created_at DESC);

-- ============================================================
-- ROW LEVEL SECURITY
-- ============================================================
ALTER TABLE agent_intercom_sessions ENABLE ROW LEVEL SECURITY;
ALTER TABLE agent_intercom_messages ENABLE ROW LEVEL SECURITY;
ALTER TABLE agent_intercom_escalations ENABLE ROW LEVEL SECURITY;
ALTER TABLE agent_intercom_audit_log ENABLE ROW LEVEL SECURITY;

-- Service role (agents) can read/write all
CREATE POLICY "service_role_all" ON agent_intercom_sessions
    FOR ALL USING (auth.role() = 'service_role');
CREATE POLICY "service_role_all" ON agent_intercom_messages
    FOR ALL USING (auth.role() = 'service_role');
CREATE POLICY "service_role_all" ON agent_intercom_escalations
    FOR ALL USING (auth.role() = 'service_role');
CREATE POLICY "service_role_all" ON agent_intercom_audit_log
    FOR ALL USING (auth.role() = 'service_role');

-- Authenticated users can read (for dashboard)
CREATE POLICY "authenticated_read" ON agent_intercom_sessions
    FOR SELECT USING (auth.role() = 'authenticated');
CREATE POLICY "authenticated_read" ON agent_intercom_messages
    FOR SELECT USING (auth.role() = 'authenticated');
CREATE POLICY "authenticated_read" ON agent_intercom_escalations
    FOR ALL USING (auth.role() = 'authenticated');
CREATE POLICY "authenticated_read" ON agent_intercom_audit_log
    FOR SELECT USING (auth.role() = 'authenticated');

-- ============================================================
-- REALTIME ENABLEMENT
-- ============================================================
-- Enable Realtime on messages table for instant delivery
ALTER PUBLICATION supabase_realtime ADD TABLE agent_intercom_messages;
ALTER PUBLICATION supabase_realtime ADD TABLE agent_intercom_sessions;
ALTER PUBLICATION supabase_realtime ADD TABLE agent_intercom_escalations;

-- ============================================================
-- AUTO-EXPIRY FUNCTION (run via pg_cron every minute)
-- ============================================================
CREATE OR REPLACE FUNCTION expire_stale_asks() RETURNS void AS $$
BEGIN
    -- Expire asks that have timed out
    UPDATE agent_intercom_messages
    SET status = 'expired',
        completed_at = NOW()
    WHERE message_type = 'ask'
      AND status IN ('sent', 'delivered', 'processing')
      AND expires_at IS NOT NULL
      AND expires_at < NOW();

    -- Expire escalations that have timed out
    UPDATE agent_intercom_escalations
    SET status = 'expired'
    WHERE status IN ('pending', 'notified')
      AND expires_at IS NOT NULL
      AND expires_at < NOW();

    -- Mark sessions with stale heartbeat as offline
    UPDATE agent_intercom_sessions
    SET status = 'offline'
    WHERE status != 'offline'
      AND heartbeat_at < NOW() - INTERVAL '2 minutes';
END;
$$ LANGUAGE plpgsql;

-- Schedule via pg_cron (if available) or Supabase Edge Function
-- SELECT cron.schedule('expire-stale-asks', '* * * * *', 'SELECT expire_stale_asks()');
```

### 4.2 TypeScript Client Library — `@insightprofit/agent-intercom`

This is the core client library that every ads app imports. It wraps Supabase operations into the pi-intercom-inspired API.

#### File: `packages/agent-intercom/src/client.ts`

```typescript
import { createClient, SupabaseClient, RealtimeChannel } from '@supabase/supabase-js';
import { v4 as uuidv4 } from 'uuid';

// ── Types ────────────────────────────────────────────────────────────────

export interface AgentConfig {
  agentId: string;                    // unique identifier (e.g., "creative-scorer")
  agentName: string;                  // human-readable name
  appSource: string;                  // which app (e.g., "ad-campaign-engine")
  capabilities: string[];             // what this agent can do
  canAnswer: string[];                // what questions this agent can answer
  model?: string;                     // LLM model
  version?: string;                   // agent version
  onMessage?: (msg: IncomingMessage) => Promise<void>;     // handler for incoming messages
  onAsk?: (ask: IncomingAsk) => Promise<AskResponse>;      // handler for incoming asks
  heartbeatIntervalMs?: number;       // default: 30000
  askTimeoutMinutes?: number;         // default: 10
}

export interface IncomingMessage {
  id: string;
  senderId: string;
  senderName: string;
  type: 'send' | 'broadcast';
  payload: MessagePayload;
  createdAt: string;
}

export interface IncomingAsk {
  id: string;
  senderId: string;
  senderName: string;
  payload: AskPayload;
  createdAt: string;
  expiresAt: string;
}

export interface AskResponse {
  answer: string;
  data?: Record<string, unknown>;
}

export interface MessagePayload {
  text: string;
  data?: Record<string, unknown>;
  attachments?: Attachment[];
}

export interface AskPayload {
  question: string;
  context?: Record<string, unknown>;
  requiredFields?: string[];
  timeoutMinutes?: number;
}

export interface ReplyPayload {
  answer: string;
  data?: Record<string, unknown>;
}

export interface Attachment {
  type: 'snippet' | 'file' | 'context';
  name: string;
  content: string;
  language?: string;
}

export interface AgentSession {
  id: string;
  agentId: string;
  agentName: string;
  appSource: string;
  capabilities: string[];
  canAnswer: string[];
  status: string;
  currentTask: string | null;
  heartbeatAt: string;
  model: string | null;
}

export interface SendResult {
  messageId: string;
  delivered: boolean;
  error?: string;
}

export interface AskResult {
  messageId: string;
  reply: ReplyPayload | null;
  timedOut: boolean;
  error?: string;
}

export type EscalationTier = 'blocking' | 'interview' | 'update';

export interface EscalationQuestion {
  id: string;
  question: string;
  type: 'text' | 'choice' | 'boolean';
  options?: string[];
}

// ── Client Class ─────────────────────────────────────────────────────────

export class AgentIntercomClient {
  private supabase: SupabaseClient;
  private config: AgentConfig;
  private sessionId: string | null = null;
  private heartbeatTimer: NodeJS.Timeout | null = null;
  private realtimeChannel: RealtimeChannel | null = null;
  private connected = false;

  constructor(
    supabaseUrl: string,
    supabaseServiceKey: string,
    config: AgentConfig,
  ) {
    this.supabase = createClient(supabaseUrl, supabaseServiceKey);
    this.config = {
      heartbeatIntervalMs: 30000,
      askTimeoutMinutes: 10,
      ...config,
    };
  }

  // ── Lifecycle ──────────────────────────────────────────────────────

  async connect(): Promise<void> {
    if (this.connected) throw new Error('Already connected');

    // Register session
    const { data, error } = await this.supabase
      .from('agent_intercom_sessions')
      .upsert({
        agent_id: this.config.agentId,
        agent_name: this.config.agentName,
        app_source: this.config.appSource,
        capabilities: this.config.capabilities,
        can_answer: this.config.canAnswer,
        status: 'idle',
        heartbeat_at: new Date().toISOString(),
        model: this.config.model || null,
        version: this.config.version || null,
        registered_at: new Date().toISOString(),
      }, { onConflict: 'agent_id,instance_id' })
      .select()
      .single();

    if (error) throw new Error(`Registration failed: ${error.message}`);
    this.sessionId = data.id;

    // Start heartbeat
    this.heartbeatTimer = setInterval(
      () => this.heartbeat(),
      this.config.heartbeatIntervalMs!,
    );

    // Subscribe to incoming messages via Realtime
    this.realtimeChannel = this.supabase
      .channel('agent-intercom')
      .on(
        'postgres_changes',
        {
          event: 'INSERT',
          schema: 'public',
          table: 'agent_intercom_messages',
          filter: `receiver_id=eq.${this.config.agentId}`,
        },
        (payload) => this.handleIncoming(payload.new),
      )
      .subscribe();

    // Audit log
    await this.audit('register', { agentId: this.config.agentId });

    this.connected = true;
  }

  async disconnect(): Promise<void> {
    if (!this.connected) return;

    // Clear heartbeat
    if (this.heartbeatTimer) {
      clearInterval(this.heartbeatTimer);
      this.heartbeatTimer = null;
    }

    // Unsubscribe Realtime
    if (this.realtimeChannel) {
      await this.supabase.removeChannel(this.realtimeChannel);
      this.realtimeChannel = null;
    }

    // Mark session offline
    if (this.sessionId) {
      await this.supabase
        .from('agent_intercom_sessions')
        .update({ status: 'offline', updated_at: new Date().toISOString() })
        .eq('id', this.sessionId);
    }

    await this.audit('deregister', { agentId: this.config.agentId });
    this.connected = false;
  }

  // ── Discovery ──────────────────────────────────────────────────────

  async listSessions(filter?: { appSource?: string; capability?: string }): Promise<AgentSession[]> {
    let query = this.supabase
      .from('agent_intercom_sessions')
      .select('*')
      .neq('status', 'offline')
      .neq('agent_id', this.config.agentId);

    if (filter?.appSource) {
      query = query.eq('app_source', filter.appSource);
    }
    if (filter?.capability) {
      query = query.contains('capabilities', [filter.capability]);
    }

    const { data, error } = await query;
    if (error) throw new Error(`List sessions failed: ${error.message}`);

    return (data || []).map(row => ({
      id: row.id,
      agentId: row.agent_id,
      agentName: row.agent_name,
      appSource: row.app_source,
      capabilities: row.capabilities,
      canAnswer: row.can_answer,
      status: row.status,
      currentTask: row.current_task,
      heartbeatAt: row.heartbeat_at,
      model: row.model,
    }));
  }

  async findAgent(capability: string): Promise<AgentSession | null> {
    const sessions = await this.listSessions({ capability });
    return sessions.find(s => s.status !== 'offline') || null;
  }

  // ── Messaging ──────────────────────────────────────────────────────

  async send(to: string, payload: MessagePayload): Promise<SendResult> {
    const messageId = uuidv4();
    const { error } = await this.supabase
      .from('agent_intercom_messages')
      .insert({
        id: messageId,
        sender_id: this.config.agentId,
        receiver_id: to,
        sender_session_id: this.sessionId,
        message_type: 'send',
        payload,
        expects_reply: false,
        status: 'sent',
      });

    if (error) return { messageId, delivered: false, error: error.message };

    await this.audit('send', { to, messageId });
    return { messageId, delivered: true };
  }

  async ask(to: string, payload: AskPayload): Promise<AskResult> {
    const messageId = uuidv4();
    const conversationId = uuidv4();
    const timeoutMinutes = payload.timeoutMinutes || this.config.askTimeoutMinutes!;
    const expiresAt = new Date(Date.now() + timeoutMinutes * 60 * 1000).toISOString();

    // Insert the ask
    const { error } = await this.supabase
      .from('agent_intercom_messages')
      .insert({
        id: messageId,
        sender_id: this.config.agentId,
        receiver_id: to,
        sender_session_id: this.sessionId,
        message_type: 'ask',
        conversation_id: conversationId,
        payload,
        expects_reply: true,
        status: 'sent',
        expires_at: expiresAt,
      });

    if (error) return { messageId, reply: null, timedOut: false, error: error.message };

    // Update own status
    await this.updateStatus('waiting', `Waiting for reply from ${to}`);
    await this.audit('ask', { to, messageId, question: payload.question });

    // Wait for reply via polling (Realtime is primary, polling is fallback)
    const reply = await this.waitForReply(messageId, timeoutMinutes);

    // Restore status
    await this.updateStatus('idle');

    if (!reply) {
      return { messageId, reply: null, timedOut: true };
    }

    return { messageId, reply, timedOut: false };
  }

  async reply(toMessageId: string, payload: ReplyPayload): Promise<SendResult> {
    // Look up the original ask to find sender
    const { data: originalMsg, error: lookupError } = await this.supabase
      .from('agent_intercom_messages')
      .select('sender_id, conversation_id')
      .eq('id', toMessageId)
      .single();

    if (lookupError || !originalMsg) {
      return { messageId: '', delivered: false, error: 'Original message not found' };
    }

    const messageId = uuidv4();
    const { error } = await this.supabase
      .from('agent_intercom_messages')
      .insert({
        id: messageId,
        sender_id: this.config.agentId,
        receiver_id: originalMsg.sender_id,
        sender_session_id: this.sessionId,
        message_type: 'reply',
        reply_to_message_id: toMessageId,
        conversation_id: originalMsg.conversation_id,
        payload,
        expects_reply: false,
        status: 'sent',
      });

    if (error) return { messageId, delivered: false, error: error.message };

    // Mark original ask as completed
    await this.supabase
      .from('agent_intercom_messages')
      .update({ status: 'completed', completed_at: new Date().toISOString() })
      .eq('id', toMessageId);

    await this.audit('reply', { toMessageId, messageId });
    return { messageId, delivered: true };
  }

  async broadcast(payload: MessagePayload): Promise<SendResult> {
    const messageId = uuidv4();
    const { error } = await this.supabase
      .from('agent_intercom_messages')
      .insert({
        id: messageId,
        sender_id: this.config.agentId,
        receiver_id: '__broadcast__',
        sender_session_id: this.sessionId,
        message_type: 'broadcast',
        payload,
        expects_reply: false,
        status: 'sent',
      });

    if (error) return { messageId, delivered: false, error: error.message };
    return { messageId, delivered: true };
  }

  // ── Escalation ─────────────────────────────────────────────────────

  async escalate(
    tier: EscalationTier,
    subject: string,
    options: {
      context?: Record<string, unknown>;
      questions?: EscalationQuestion[];
      timeoutMinutes?: number;
    } = {},
  ): Promise<{ escalationId: string; response: Record<string, unknown> | null; expired: boolean }> {
    const escalationId = uuidv4();
    const timeoutMinutes = options.timeoutMinutes || (tier === 'interview' ? 30 : 10);
    const expiresAt = new Date(Date.now() + timeoutMinutes * 60 * 1000).toISOString();

    const { error } = await this.supabase
      .from('agent_intercom_escalations')
      .insert({
        id: escalationId,
        agent_id: this.config.agentId,
        agent_session_id: this.sessionId,
        tier,
        subject,
        context: options.context || {},
        questions: options.questions || null,
        status: 'pending',
        timeout_minutes: timeoutMinutes,
        expires_at: expiresAt,
      });

    if (error) throw new Error(`Escalation failed: ${error.message}`);

    await this.audit('escalate', { tier, subject, escalationId });

    // For UPDATE tier: fire-and-forget
    if (tier === 'update') {
      return { escalationId, response: null, expired: false };
    }

    // For BLOCKING and INTERVIEW: wait for response
    await this.updateStatus('blocked', `Escalated: ${subject}`);

    const response = await this.waitForEscalationResponse(escalationId, timeoutMinutes);

    await this.updateStatus('idle');

    return {
      escalationId,
      response,
      expired: response === null,
    };
  }

  // ── Status ─────────────────────────────────────────────────────────

  async updateStatus(status: string, currentTask?: string): Promise<void> {
    if (!this.sessionId) return;
    await this.supabase
      .from('agent_intercom_sessions')
      .update({
        status,
        current_task: currentTask || null,
        updated_at: new Date().toISOString(),
      })
      .eq('id', this.sessionId);
  }

  // ── Private Methods ────────────────────────────────────────────────

  private async heartbeat(): Promise<void> {
    if (!this.sessionId) return;
    await this.supabase
      .from('agent_intercom_sessions')
      .update({ heartbeat_at: new Date().toISOString() })
      .eq('id', this.sessionId);
  }

  private async handleIncoming(row: Record<string, unknown>): Promise<void> {
    const messageType = row.message_type as string;

    // Acknowledge delivery
    await this.supabase
      .from('agent_intercom_messages')
      .update({ status: 'delivered', delivered_at: new Date().toISOString() })
      .eq('id', row.id);

    if (messageType === 'send' || messageType === 'broadcast') {
      // Get sender name for context
      const senderName = await this.getSenderName(row.sender_id as string);
      if (this.config.onMessage) {
        await this.config.onMessage({
          id: row.id as string,
          senderId: row.sender_id as string,
          senderName,
          type: messageType as 'send' | 'broadcast',
          payload: row.payload as MessagePayload,
          createdAt: row.created_at as string,
        });
      }
    } else if (messageType === 'ask') {
      const senderName = await this.getSenderName(row.sender_id as string);
      if (this.config.onAsk) {
        // Mark as processing
        await this.supabase
          .from('agent_intercom_messages')
          .update({ status: 'processing' })
          .eq('id', row.id);

        await this.updateStatus('processing', `Answering ${senderName}`);

        const response = await this.config.onAsk({
          id: row.id as string,
          senderId: row.sender_id as string,
          senderName,
          payload: row.payload as AskPayload,
          createdAt: row.created_at as string,
          expiresAt: row.expires_at as string,
        });

        // Auto-reply
        await this.reply(row.id as string, response);
        await this.updateStatus('idle');
      }
    }
    // 'reply' type messages are handled by waitForReply()
  }

  private async waitForReply(
    askMessageId: string,
    timeoutMinutes: number,
  ): Promise<ReplyPayload | null> {
    const deadline = Date.now() + timeoutMinutes * 60 * 1000;
    const pollIntervalMs = 3000;

    while (Date.now() < deadline) {
      const { data } = await this.supabase
        .from('agent_intercom_messages')
        .select('payload')
        .eq('reply_to_message_id', askMessageId)
        .eq('message_type', 'reply')
        .limit(1)
        .maybeSingle();

      if (data) {
        return data.payload as ReplyPayload;
      }

      await new Promise(resolve => setTimeout(resolve, pollIntervalMs));
    }

    // Timeout — mark original ask as expired
    await this.supabase
      .from('agent_intercom_messages')
      .update({ status: 'expired', completed_at: new Date().toISOString() })
      .eq('id', askMessageId);

    return null;
  }

  private async waitForEscalationResponse(
    escalationId: string,
    timeoutMinutes: number,
  ): Promise<Record<string, unknown> | null> {
    const deadline = Date.now() + timeoutMinutes * 60 * 1000;
    const pollIntervalMs = 5000;

    while (Date.now() < deadline) {
      const { data } = await this.supabase
        .from('agent_intercom_escalations')
        .select('response, status')
        .eq('id', escalationId)
        .single();

      if (data?.status === 'responded' && data.response) {
        return data.response as Record<string, unknown>;
      }

      await new Promise(resolve => setTimeout(resolve, pollIntervalMs));
    }

    return null;
  }

  private async getSenderName(agentId: string): Promise<string> {
    const { data } = await this.supabase
      .from('agent_intercom_sessions')
      .select('agent_name')
      .eq('agent_id', agentId)
      .maybeSingle();
    return data?.agent_name || agentId;
  }

  private async audit(eventType: string, details: Record<string, unknown>): Promise<void> {
    await this.supabase
      .from('agent_intercom_audit_log')
      .insert({
        event_type: eventType,
        agent_id: this.config.agentId,
        target_agent_id: (details.to as string) || null,
        message_id: (details.messageId as string) || null,
        escalation_id: (details.escalationId as string) || null,
        details,
      });
  }
}
```

#### File: `packages/agent-intercom/src/index.ts`

```typescript
export { AgentIntercomClient } from './client';
export type {
  AgentConfig,
  IncomingMessage,
  IncomingAsk,
  AskResponse,
  MessagePayload,
  AskPayload,
  ReplyPayload,
  Attachment,
  AgentSession,
  SendResult,
  AskResult,
  EscalationTier,
  EscalationQuestion,
} from './client';
