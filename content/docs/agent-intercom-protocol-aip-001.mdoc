  --repo ad-campaign-engine \
  --agent codex \
  --task "Implement Agent Intercom Protocol Phase 1: Run Supabase schema migration, create @insightprofit/agent-intercom client library, add convex/agentIntercom.ts. See CLAUDE.md for full spec." \
  --priority high

# Phase 2: Agent Wiring (per app)
uv run python skills/agent_dispatch_bridge/scripts/dispatch_task.py \
  --repo ad-campaign-engine \
  --agent cursor \
  --task "Wire AIP into existing agent modules: creativeScoring.ts, growthStage.ts, campaigns.ts. Add onMessage/onAsk handlers. See CLAUDE.md." \
  --priority high

# Phase 3: Dashboard
uv run python skills/agent_dispatch_bridge/scripts/dispatch_task.py \
  --repo insightprofit-command-v2 \
  --agent codex \
  --task "Build Agent Intercom Dashboard view with live Supabase Realtime. See CLAUDE.md." \
