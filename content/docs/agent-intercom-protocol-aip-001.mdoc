## 7. Testing & Verification

### 7.1 Unit Tests

```typescript
// packages/agent-intercom/tests/client.test.ts

import { describe, it, expect, beforeAll, afterAll } from 'vitest';
import { AgentIntercomClient } from '../src/client';

const SUPABASE_URL = process.env.SUPABASE_URL!;
const SUPABASE_KEY = process.env.SUPABASE_SERVICE_KEY!;

describe('AgentIntercomClient', () => {
  let agentA: AgentIntercomClient;
  let agentB: AgentIntercomClient;

  beforeAll(async () => {
    agentA = new AgentIntercomClient(SUPABASE_URL, SUPABASE_KEY, {
      agentId: 'test-agent-a',
      agentName: 'Test Agent A',
      appSource: 'test',
      capabilities: ['test_capability'],
      canAnswer: ['test questions'],
    });

    agentB = new AgentIntercomClient(SUPABASE_URL, SUPABASE_KEY, {
      agentId: 'test-agent-b',
      agentName: 'Test Agent B',
      appSource: 'test',
      capabilities: ['answer_capability'],
      canAnswer: ['can answer test questions'],
      onMessage: async (msg) => {
        console.log('Agent B received:', msg.payload.text);
      },
      onAsk: async (ask) => {
        return { answer: 'Test answer', data: { computed: true } };
      },
    });

    await agentA.connect();
    await agentB.connect();
  });

  afterAll(async () => {
    await agentA.disconnect();
    await agentB.disconnect();
  });

  it('should register and discover sessions', async () => {
    const sessions = await agentA.listSessions();
    expect(sessions.some(s => s.agentId === 'test-agent-b')).toBe(true);
  });

  it('should find agent by capability', async () => {
    const agent = await agentA.findAgent('answer_capability');
    expect(agent).not.toBeNull();
    expect(agent!.agentId).toBe('test-agent-b');
  });

  it('should send fire-and-forget message', async () => {
    const result = await agentA.send('test-agent-b', {
      text: 'Hello from Agent A',
      data: { important: true },
    });
    expect(result.delivered).toBe(true);
  });

  it('should ask and receive blocking reply', async () => {
    const result = await agentA.ask('test-agent-b', {
      question: 'What is the answer?',
      context: { topic: 'test' },
      timeoutMinutes: 1,
    });
    expect(result.timedOut).toBe(false);
    expect(result.reply).not.toBeNull();
    expect(result.reply!.answer).toBe('Test answer');
    expect(result.reply!.data).toEqual({ computed: true });
  });

  it('should handle ask timeout gracefully', async () => {
    // Create agent C with no onAsk handler (won't reply)
    const agentC = new AgentIntercomClient(SUPABASE_URL, SUPABASE_KEY, {
      agentId: 'test-agent-c',
      agentName: 'Test Agent C (No Reply)',
      appSource: 'test',
      capabilities: [],
      canAnswer: [],
      askTimeoutMinutes: 0.1, // 6 seconds
    });
    await agentC.connect();

    const result = await agentA.ask('test-agent-c', {
      question: 'Will you reply?',
      timeoutMinutes: 0.1, // 6 seconds
    });

    expect(result.timedOut).toBe(true);
    expect(result.reply).toBeNull();

    await agentC.disconnect();
  });

  it('should escalate to human (update tier)', async () => {
    const result = await agentA.escalate('update', 'Test progress update', {
      context: { progress: '50%' },
    });
    expect(result.escalationId).toBeDefined();
    expect(result.expired).toBe(false);
  });
});
```

### 7.2 Integration Test Scenarios

| Test | Agents Involved | Expected Outcome |
|------|----------------|-----------------|
| Creative scoring pipeline | creative-factory → creative-scorer → campaign-ops | Batch scored, top creatives launched |
| Fatigue auto-pause | creative-scorer → campaign-ops → creative-factory | Fatigued ad paused, replacement generated |
| Stage transition | dtc-strategist → budget-optimizer → audience-builder | New strategy with reallocated budget |
| Cross-app pricing | offer-architect → revenue-intel → umdm-etl | Optimal price calculated from LTV + CPA |
| Escalation round-trip | any-agent → Slack → human → agent | Agent unblocks with human decision |
| Stale session cleanup | N/A (cron) | Offline sessions cleaned after 2 min |
| Concurrent asks | 10 agents asking simultaneously | All receive replies, no deadlocks |

