### 4.3 Convex Integration Layer

Since our ads apps use Convex, we need a bridge that lets Convex actions call the Supabase-backed AIP.

#### File: `convex/agentIntercom.ts` (Add to each Convex app)

```typescript
"use node";
import { action } from "./_generated/server";
import { v } from "convex/values";
import { AgentIntercomClient } from "@insightprofit/agent-intercom";

// ── Shared client factory ────────────────────────────────────────────

function createIntercomClient(agentId: string, agentName: string, appSource: string) {
  const supabaseUrl = process.env.SUPABASE_URL!;
  const supabaseKey = process.env.SUPABASE_SERVICE_KEY!;

  return new AgentIntercomClient(supabaseUrl, supabaseKey, {
    agentId,
    agentName,
    appSource,
    capabilities: [],
    canAnswer: [],
  });
}

// ── Actions ──────────────────────────────────────────────────────────

export const sendMessage = action({
  args: {
    fromAgentId: v.string(),
    fromAgentName: v.string(),
    toAgentId: v.string(),
    text: v.string(),
    data: v.optional(v.any()),
  },
  handler: async (ctx, args) => {
    const client = createIntercomClient(args.fromAgentId, args.fromAgentName, "ad-campaign-engine");
    await client.connect();
    try {
      const result = await client.send(args.toAgentId, {
        text: args.text,
        data: args.data || undefined,
      });
      return result;
    } finally {
      await client.disconnect();
    }
  },
});

export const askAgent = action({
  args: {
    fromAgentId: v.string(),
    fromAgentName: v.string(),
    toAgentId: v.string(),
    question: v.string(),
    context: v.optional(v.any()),
    timeoutMinutes: v.optional(v.number()),
  },
  handler: async (ctx, args) => {
    const client = createIntercomClient(args.fromAgentId, args.fromAgentName, "ad-campaign-engine");
    await client.connect();
    try {
      const result = await client.ask(args.toAgentId, {
        question: args.question,
        context: args.context || undefined,
        timeoutMinutes: args.timeoutMinutes || 10,
      });
      return result;
    } finally {
      await client.disconnect();
    }
  },
});

export const replyToAsk = action({
  args: {
    agentId: v.string(),
    agentName: v.string(),
    originalMessageId: v.string(),
    answer: v.string(),
    data: v.optional(v.any()),
  },
  handler: async (ctx, args) => {
    const client = createIntercomClient(args.agentId, args.agentName, "ad-campaign-engine");
    await client.connect();
    try {
      const result = await client.reply(args.originalMessageId, {
        answer: args.answer,
        data: args.data || undefined,
      });
      return result;
    } finally {
      await client.disconnect();
    }
  },
});

export const listActiveSessions = action({
  args: {
    capability: v.optional(v.string()),
    appSource: v.optional(v.string()),
  },
  handler: async (ctx, args) => {
    const client = createIntercomClient("system", "System", "ad-campaign-engine");
    await client.connect();
    try {
      return await client.listSessions({
        capability: args.capability || undefined,
        appSource: args.appSource || undefined,
      });
    } finally {
      await client.disconnect();
    }
  },
});

export const escalateToHuman = action({
  args: {
    agentId: v.string(),
    agentName: v.string(),
    tier: v.union(v.literal("blocking"), v.literal("interview"), v.literal("update")),
    subject: v.string(),
    context: v.optional(v.any()),
    questions: v.optional(v.array(v.object({
      id: v.string(),
      question: v.string(),
      type: v.union(v.literal("text"), v.literal("choice"), v.literal("boolean")),
      options: v.optional(v.array(v.string())),
    }))),
  },
  handler: async (ctx, args) => {
    const client = createIntercomClient(args.agentId, args.agentName, "ad-campaign-engine");
    await client.connect();
    try {
      return await client.escalate(args.tier, args.subject, {
        context: args.context || undefined,
        questions: args.questions || undefined,
      });
    } finally {
      await client.disconnect();
    }
  },
});
```

### 4.4 Command Center Dashboard Component

#### File: `src/views/AgentIntercomView.tsx` (Add to Command Center v2)

```tsx
// Agent Intercom Dashboard — Real-time monitoring of agent sessions,
// messages, and escalations. Supabase Realtime subscription for live updates.

'use client';

import { useEffect, useState } from 'react';
import { createClient } from '@supabase/supabase-js';

interface AgentSession {
  id: string;
  agent_id: string;
  agent_name: string;
  app_source: string;
  capabilities: string[];
  status: string;
  current_task: string | null;
  heartbeat_at: string;
}

interface IntercomMessage {
  id: string;
  sender_id: string;
  receiver_id: string;
  message_type: string;
  payload: Record<string, unknown>;
  status: string;
  created_at: string;
}

interface Escalation {
  id: string;
  agent_id: string;
  tier: string;
  subject: string;
  status: string;
  created_at: string;
}

export default function AgentIntercomView() {
  const [sessions, setSessions] = useState<AgentSession[]>([]);
  const [messages, setMessages] = useState<IntercomMessage[]>([]);
  const [escalations, setEscalations] = useState<Escalation[]>([]);
  const [activeTab, setActiveTab] = useState<'sessions' | 'messages' | 'escalations'>('sessions');

  // Initialize Supabase client and subscribe to Realtime
  useEffect(() => {
    const supabase = createClient(
      process.env.NEXT_PUBLIC_SUPABASE_URL!,
      process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    );

    // Fetch initial data
    const fetchData = async () => {
      const [sessionsRes, messagesRes, escalationsRes] = await Promise.all([
        supabase.from('agent_intercom_sessions').select('*').neq('status', 'offline').order('heartbeat_at', { ascending: false }),
        supabase.from('agent_intercom_messages').select('*').order('created_at', { ascending: false }).limit(100),
        supabase.from('agent_intercom_escalations').select('*').order('created_at', { ascending: false }).limit(50),
      ]);

      if (sessionsRes.data) setSessions(sessionsRes.data);
      if (messagesRes.data) setMessages(messagesRes.data);
      if (escalationsRes.data) setEscalations(escalationsRes.data);
    };

    fetchData();

    // Subscribe to Realtime updates
    const channel = supabase
      .channel('intercom-dashboard')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'agent_intercom_sessions' }, () => fetchData())
      .on('postgres_changes', { event: '*', schema: 'public', table: 'agent_intercom_messages' }, () => fetchData())
      .on('postgres_changes', { event: '*', schema: 'public', table: 'agent_intercom_escalations' }, () => fetchData())
      .subscribe();

    return () => { supabase.removeChannel(channel); };
  }, []);

  // Component renders session cards, message timeline, escalation queue
  // (Full JSX implementation for the harness to build)
  return (
    <div className="p-6 space-y-6">
      <h1 className="text-2xl font-bold">🔌 Agent Intercom — Live Dashboard</h1>

      {/* Tab Navigation */}
      <div className="flex gap-2 border-b">
        {(['sessions', 'messages', 'escalations'] as const).map(tab => (
          <button
            key={tab}
            onClick={() => setActiveTab(tab)}
            className={`px-4 py-2 capitalize ${activeTab === tab ? 'border-b-2 border-blue-500 font-semibold' : 'text-gray-500'}`}
          >
            {tab} ({tab === 'sessions' ? sessions.length : tab === 'messages' ? messages.length : escalations.filter(e => e.status === 'pending').length})
          </button>
        ))}
      </div>

      {/* Sessions Tab */}
      {activeTab === 'sessions' && (
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {sessions.map(session => (
            <div key={session.id} className="border rounded-lg p-4 space-y-2">
              <div className="flex items-center justify-between">
                <span className="font-semibold">{session.agent_name}</span>
                <span className={`px-2 py-0.5 rounded text-xs ${
                  session.status === 'idle' ? 'bg-green-100 text-green-800' :
                  session.status === 'processing' ? 'bg-blue-100 text-blue-800' :
                  session.status === 'waiting' ? 'bg-yellow-100 text-yellow-800' :
                  session.status === 'blocked' ? 'bg-red-100 text-red-800' :
                  'bg-gray-100 text-gray-800'
                }`}>
                  {session.status}
                </span>
              </div>
              <div className="text-sm text-gray-500">{session.app_source}</div>
              {session.current_task && (
                <div className="text-sm italic">📋 {session.current_task}</div>
              )}
              <div className="flex flex-wrap gap-1">
                {session.capabilities.slice(0, 4).map(cap => (
                  <span key={cap} className="text-xs bg-gray-100 px-2 py-0.5 rounded">{cap}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Messages Tab */}
      {activeTab === 'messages' && (
        <div className="space-y-2">
          {messages.map(msg => (
            <div key={msg.id} className="border rounded p-3 flex items-start gap-3">
              <span className={`text-xs px-2 py-0.5 rounded font-mono ${
                msg.message_type === 'ask' ? 'bg-purple-100 text-purple-800' :
                msg.message_type === 'reply' ? 'bg-green-100 text-green-800' :
                msg.message_type === 'broadcast' ? 'bg-blue-100 text-blue-800' :
                'bg-gray-100 text-gray-800'
              }`}>
                {msg.message_type}
              </span>
              <div className="flex-1 min-w-0">
                <div className="text-sm">
                  <span className="font-semibold">{msg.sender_id}</span>
                  <span className="text-gray-400"> → </span>
                  <span className="font-semibold">{msg.receiver_id}</span>
                </div>
                <div className="text-sm text-gray-600 truncate">
                  {(msg.payload as any)?.text || (msg.payload as any)?.question || (msg.payload as any)?.answer || '—'}
                </div>
              </div>
              <span className={`text-xs px-2 py-0.5 rounded ${
                msg.status === 'completed' ? 'bg-green-100' :
                msg.status === 'expired' ? 'bg-red-100' :
                'bg-yellow-100'
              }`}>
                {msg.status}
              </span>
            </div>
          ))}
        </div>
      )}

      {/* Escalations Tab */}
      {activeTab === 'escalations' && (
        <div className="space-y-2">
          {escalations.map(esc => (
            <div key={esc.id} className={`border rounded p-3 ${
              esc.status === 'pending' ? 'border-red-300 bg-red-50' : ''
            }`}>
              <div className="flex items-center gap-2">
                <span className={`text-xs px-2 py-0.5 rounded font-mono ${
                  esc.tier === 'blocking' ? 'bg-red-100 text-red-800' :
                  esc.tier === 'interview' ? 'bg-purple-100 text-purple-800' :
                  'bg-blue-100 text-blue-800'
                }`}>
                  {esc.tier}
                </span>
                <span className="font-semibold text-sm">{esc.agent_id}</span>
                <span className="text-sm text-gray-500">{esc.subject}</span>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}
```

