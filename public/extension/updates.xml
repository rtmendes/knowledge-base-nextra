<?xml version='1.0' encoding='UTF-8'?>
<!--
  Chrome Extension Auto-Update Manifest
  ======================================
  This file is fetched by Chrome (every 4-25 hours) to check if a newer
  version of the Genspark KB Extractor extension is available.

  The appid below must match your extension's actual Chrome ID.
  It is auto-updated by GitHub Actions (pack-extension.yml) after every push.

  To find your extension ID:
    1. Run the GitHub Action once to generate the .crx
    2. Drag the .crx onto chrome://extensions/
    3. Copy the 32-character ID shown there
    4. Add it as a GitHub Actions variable: EXTENSION_ID

  Auto-update ONLY works when the extension was installed from this .crx file
  (not from "Load unpacked"). You need to switch once via drag-and-drop.
-->
<gupdate xmlns='http://www.google.com/update2/response' protocol='2.0'>
  <app appid='YOUR_EXTENSION_ID_HERE'>
    <updatecheck
      codebase='https://kb.insightprofit.live/extension/genspark-kb-extractor.crx'
      version='1.2.0'/>
  </app>
</gupdate>
